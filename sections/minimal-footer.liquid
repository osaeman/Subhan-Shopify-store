<section
  id="MinimalFooter-{{ section.id }}"
  class="minimal-footer section-{{ section.id }}-padding"
  role="contentinfo"
  aria-label="{{ section.settings.accessibility_label | escape }}">
  <div class="minimal-footer__inner">
    {%- comment -%} 
                                                TOP GRID: CONTACT (LEFT) + FEEDBACK FORM (RIGHT)
                                {%- endcomment -%}
    <div class="minimal-footer__top">
      <div class="minimal-footer__contact">
        {% if section.settings.contact_heading != blank %}
          <h2 class="minimal-footer__heading">
            {{ section.settings.contact_heading }}
          </h2>
        {% endif %}

        <ul class="minimal-footer__contact-list">
          {% if section.settings.contact_address != blank %}
            <li class="minimal-footer__contact-item">
              {% if section.settings.show_contact_icons %}
                <span class="minimal-footer__icon minimal-footer__icon--address" aria-hidden="true">
                  <!-- simple pin icon -->
                  <svg
                    class="minimal-footer__icon-svg"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 384 512">
                      <!-- !Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc. -->
                    <path d="M0 188.6C0 84.4 86 0 192 0S384 84.4 384 188.6c0 119.3-120.2 262.3-170.4 316.8-11.8 12.8-31.5 12.8-43.3 0-50.2-54.5-170.4-197.5-170.4-316.8zM192 256a64 64 0 1 0 0-128 64 64 0 1 0 0 128z" />
                  </svg>
                </span>
              {% endif %}
              <span class="minimal-footer__contact-label">
                {{ section.settings.contact_address }}
              </span>
            </li>
          {% endif %}

          {% if section.settings.contact_phone != blank %}
            <li class="minimal-footer__contact-item">
              {% if section.settings.show_contact_icons %}
                <span class="minimal-footer__icon minimal-footer__icon--phone" aria-hidden="true">
                  <svg
                    class="minimal-footer__icon-svg"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 512 512">
                      <!-- !Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc. -->
                    <path d="M160.2 25C152.3 6.1 131.7-3.9 112.1 1.4l-5.5 1.5c-64.6 17.6-119.8 80.2-103.7 156.4 37.1 175 174.8 312.7 349.8 349.8 76.3 16.2 138.8-39.1 156.4-103.7l1.5-5.5c5.4-19.7-4.7-40.3-23.5-48.1l-97.3-40.5c-16.5-6.9-35.6-2.1-47 11.8l-38.6 47.2C233.9 335.4 177.3 277 144.8 205.3L189 169.3c13.9-11.3 18.6-30.4 11.8-47L160.2 25z" />
                  </svg>
                </span>
              {% endif %}
              <a href="tel:{{ section.settings.contact_phone | replace: ' ', '' }}" class="minimal-footer__contact-link">
                {{ section.settings.contact_phone }}
              </a>
            </li>
          {% endif %}

          {% if section.settings.contact_email != blank %}
            <li class="minimal-footer__contact-item">
              {% if section.settings.show_contact_icons %}
                <span class="minimal-footer__icon minimal-footer__icon--email" aria-hidden="true">
                  <svg
                    class="minimal-footer__icon-svg"
                    xmlns="http://www.w3.org/2000/svg"
                    viewBox="0 0 512 512">
                      <!-- !Font Awesome Free v7.2.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc. -->
                    <path d="M48 64c-26.5 0-48 21.5-48 48 0 15.1 7.1 29.3 19.2 38.4l208 156c17.1 12.8 40.5 12.8 57.6 0l208-156c12.1-9.1 19.2-23.3 19.2-38.4 0-26.5-21.5-48-48-48L48 64zM0 196L0 384c0 35.3 28.7 64 64 64l384 0c35.3 0 64-28.7 64-64l0-188-198.4 148.8c-34.1 25.6-81.1 25.6-115.2 0L0 196z" />
                  </svg>
                </span>
              {% endif %}
              <a href="mailto:{{ section.settings.contact_email }}" class="minimal-footer__contact-link">
                {{ section.settings.contact_email }}
              </a>
            </li>
          {% endif %}
        </ul>
      </div>

      <div class="minimal-footer__feedback">
        {% if section.settings.form_heading != blank %}
          <h3 class="minimal-footer__form-heading">
            {{ section.settings.form_heading }}
          </h3>
        {% endif %}
        {% form 'contact'
          , id: 'MinimalFooterForm'
          , class: 'minimal-footer__form'
          , novalidate: 'novalidate' %}
          {% if form.posted_successfully? %}
            <div
              class="minimal-footer__form-status"
              tabindex="-1"
              autofocus>
              Thank you! Your feedback has been submitted successfully.
            </div>
          {% endif %}

          {% if form.errors %}
            <div class="minimal-footer__form-errors">
              {{ form.errors | default_errors }}
            </div>
          {% endif %}

          <div class="minimal-footer__form-row">
            <label class="minimal-footer__label" for="MinimalFooter-name-{{ section.id }}">
              {{ section.settings.label_name }}
            </label>
            <input
              id="MinimalFooter-name-{{ section.id }}"
              type="text"
              name="contact[name]"
              class="minimal-footer__input"
              placeholder="{{ section.settings.placeholder_name }}"
              value="{% if form.name %}{{ form.name | escape }}{% endif %}"
              autocomplete="name">
          </div>

          <div class="minimal-footer__form-row">
            <label class="minimal-footer__label" for="MinimalFooter-email-{{ section.id }}">
              {{ section.settings.label_email }}
            </label>
            <input
              id="MinimalFooter-email-{{ section.id }}"
              type="email"
              name="contact[email]"
              class="minimal-footer__input"
              placeholder="{{ section.settings.placeholder_email }}"
              value="{% if form.email %}{{ form.email | escape }}{% endif %}"
              autocomplete="email"
              required>
          </div>

          <div class="minimal-footer__form-row minimal-footer__form-row--rating">
            <span class="minimal-footer__label">
              {{ section.settings.label_rating }}
            </span>
            <div class="minimal-footer__stars" aria-label="{{ section.settings.label_rating }}">
              {% for i in (1..5) %}
                {%- assign value = 6 | minus: i -%}
                <input
                  type="radio"
                  id="MinimalFooter-star-{{ value }}-{{ section.id }}"
                  name="rating"
                  value="{{ value }}"
                  class="minimal-footer__star-input"
                  {% if value == 5 %}
                  checked{% endif %}>
                <label
                  for="MinimalFooter-star-{{ value }}-{{ section.id }}"
                  class="minimal-footer__star-label"
                  aria-label="{{ value }} star{% if value != 1 %}s{% endif %}">
                  ★
                </label>
              {% endfor %}
            </div>
          </div>

          <div class="minimal-footer__form-row">
            <label class="minimal-footer__label" for="MinimalFooter-message-visible-{{ section.id }}">
              {{ section.settings.label_message }}
            </label>
            <textarea
              id="MinimalFooter-message-visible-{{ section.id }}"
              rows="{{ section.settings.textarea_rows }}"
              class="minimal-footer__textarea"
              placeholder="{{ section.settings.placeholder_message }}"
              required>
              {% if form.body %}
                {{ form.body | escape }}{% endif %}
            </textarea>
          </div>

          <textarea
            id="MinimalFooter-message-hidden-{{ section.id }}"
            name="contact[body]"
            hidden></textarea>

          <div class="minimal-footer__form-row minimal-footer__form-row--submit">
            <button type="submit" class="minimal-footer__button">
              {{ section.settings.button_label }}
            </button>
          </div>
        {% endform %}

      </div>
    </div>

    {%- comment -%} 
                                                SEPARATOR
                                {%- endcomment -%}
    <div class="minimal-footer__divider">-</div>

    {%- comment -%} 
                                                BOTTOM BAR: TEXT LEFT + SOCIAL ICONS RIGHT
                                {%- endcomment -%}
    <div class="minimal-footer__bottom">
      <div class="minimal-footer__bottom-left">
        {% if section.settings.bottom_text != blank %}
          <p class="minimal-footer__bottom-text">
            {{ section.settings.bottom_text }}
          </p>
        {% endif %}
      </div>

      <div class="minimal-footer__bottom-right">
        <ul class="minimal-footer__social-list" aria-label="Social media">
          {% if section.settings.social_facebook_url != blank %}
            <li class="minimal-footer__social-item">
              <a
                href="{{ section.settings.social_facebook_url }}"
                class="minimal-footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Facebook">
                <span class="minimal-footer__social-icon minimal-footer__social-icon--facebook" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M22 12.07C22 6.49 17.52 2 12 2S2 6.49 2 12.07c0 5.03 3.66 9.2 8.44 9.93v-7.02H7.9v-2.91h2.54V9.84c0-2.5 1.49-3.88 3.77-3.88 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.44 2.91h-2.34V22c4.78-.73 8.44-4.9 8.44-9.93z" />
                  </svg>
                </span>
              </a>
            </li>
          {% endif %}

          {% if section.settings.social_instagram_url != blank %}
            <li class="minimal-footer__social-item">
              <a
                href="{{ section.settings.social_instagram_url }}"
                class="minimal-footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Instagram">
                <span class="minimal-footer__social-icon minimal-footer__social-icon--instagram" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M7.75 2C4.57 2 2 4.57 2 7.75v8.5C2 19.43 4.57 22 7.75 22h8.5C19.43 22 22 19.43 22 16.25v-8.5C22 4.57 19.43 2 16.25 2h-8.5zm4.25 5.5A4.75 4.75 0 1 1 7.25 12 4.75 4.75 0 0 1 12 7.5zm5.25-.75a1.25 1.25 0 1 1-1.25 1.25 1.25 1.25 0 0 1 1.25-1.25z" />
                  </svg>
                </span>
              </a>
            </li>
          {% endif %}

          {% if section.settings.social_tiktok_url != blank %}
            <li class="minimal-footer__social-item">
              <a
                href="{{ section.settings.social_tiktok_url }}"
                class="minimal-footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="TikTok">
                <span class="minimal-footer__social-icon minimal-footer__social-icon--tiktok" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M16 2c.3 1.7 1.3 3.1 2.7 4 1 .6 2.1.9 3.3.9v3c-1.4 0-2.8-.3-4-1v6.5A6.5 6.5 0 1 1 11.5 9h3v3a3.5 3.5 0 1 0 3.5 3.5V2h-2z" />
                  </svg>
                </span>
              </a>
            </li>
          {% endif %}

          {% if section.settings.social_whatsapp_url != blank %}
            <li class="minimal-footer__social-item">
              <a
                href="{{ section.settings.social_whatsapp_url }}"
                class="minimal-footer__social-link"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="WhatsApp">
                <span class="minimal-footer__social-icon minimal-footer__social-icon--whatsapp" aria-hidden="true">
                  <svg viewBox="0 0 24 24">
                    <path d="M20.52 3.48A11.82 11.82 0 0012.06 0C5.44 0 .05 5.39.05 12.01c0 2.12.55 4.18 1.6 6L0 24l6.16-1.62a11.96 11.96 0 005.9 1.5h.01c6.62 0 12.01-5.39 12.01-12.01 0-3.21-1.25-6.22-3.56-8.39zM12.07 21.75a9.7 9.7 0 01-4.94-1.36l-.35-.2-3.66.96.98-3.57-.23-.37a9.67 9.67 0 01-1.48-5.2c0-5.36 4.36-9.72 9.72-9.72 2.6 0 5.05 1.01 6.89 2.85a9.68 9.68 0 012.83 6.88c0 5.36-4.36 9.73-9.72 9.73zm5.34-7.28c-.29-.15-1.72-.85-1.98-.94-.26-.1-.45-.15-.64.15-.19.29-.73.94-.9 1.13-.16.19-.33.22-.62.07-.29-.15-1.23-.45-2.34-1.44-.87-.78-1.46-1.74-1.63-2.03-.17-.29-.02-.45.13-.6.13-.13.29-.33.44-.49.15-.16.19-.29.29-.48.1-.19.05-.36-.02-.51-.07-.15-.64-1.54-.87-2.11-.23-.55-.46-.48-.64-.49h-.54c-.19 0-.49.07-.75.36-.26.29-.98.96-.98 2.34s1.01 2.71 1.15 2.9c.15.19 1.98 3.02 4.8 4.23.67.29 1.19.46 1.6.59.67.21 1.28.18 1.76.11.54-.08 1.72-.7 1.96-1.37.24-.67.24-1.25.17-1.37-.07-.11-.26-.18-.55-.33z" />
                  </svg>
                </span>
              </a>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </div>

  {% style %}
    #MinimalFooter-{{ section.id }} {
      /* Layout & background */
      --footer-bg: {{ section.settings.section_bg_color }};
      --footer-inner-radius: {{ section.settings.section_border_radius }}px;
      --footer-inner-shadow: {{ section.settings.section_shadow }};
      --footer-max-width: {{ section.settings.section_max_width }}px;
      width: 100%;
      background-color: var(--footer-bg);

      /* Padding */
      --pad-top-m: {{ section.settings.section_padding_top_mobile }}px;
      --pad-bottom-m: {{ section.settings.section_padding_bottom_mobile }}px;
      --pad-top-t: {{ section.settings.section_padding_top_tablet }}px;
      --pad-bottom-t: {{ section.settings.section_padding_bottom_tablet }}px;
      --pad-top-d: {{ section.settings.section_padding_top_desktop }}px;
      --pad-bottom-d: {{ section.settings.section_padding_bottom_desktop }}px;

      /* Grid gaps */
      --grid-gap-m: {{ section.settings.grid_gap_mobile }}px;
      --grid-gap-t: {{ section.settings.grid_gap_tablet }}px;
      --grid-gap-d: {{ section.settings.grid_gap_desktop }}px;

      /* Typography - headings */
      --heading-color: {{ section.settings.heading_color }};
      --heading-weight: {{ section.settings.heading_weight }};
      --heading-size-m: {{ section.settings.heading_size_mobile }}px;
      --heading-size-t: {{ section.settings.heading_size_tablet }}px;
      --heading-size-d: {{ section.settings.heading_size_desktop }}px;
      --heading-lh: {{ section.settings.heading_line_height | divided_by: 100.0 }};
      --heading-letter-spacing: {{ section.settings.heading_letter_spacing | divided_by: 1000.0 }}em;

      /* Typography - body / labels */
      --text-color: {{ section.settings.text_color }};
      --text-size-m: {{ section.settings.text_size_mobile }}px;
      --text-size-t: {{ section.settings.text_size_tablet }}px;
      --text-size-d: {{ section.settings.text_size_desktop }}px;
      --text-lh: {{ section.settings.text_line_height | divided_by: 100.0 }};

      /* Form controls */
      --input-bg: {{ section.settings.input_bg_color }};
      --input-border-color: {{ section.settings.input_border_color }};
      --input-border-radius: {{ section.settings.input_border_radius }}px;
      --input-border-width: {{ section.settings.input_border_width }}px;
      --input-padding-v: {{ section.settings.input_padding_vertical }}px;
      --input-padding-h: {{ section.settings.input_padding_horizontal }}px;
      --input-gap: {{ section.settings.input_vertical_gap }}px;
      --input-shadow-normal: {{ section.settings.input_shadow }};
      --input-shadow-focus: {{ section.settings.input_shadow_focus }};
      --input-focus-border-color: {{ section.settings.input_focus_border_color }};
      --input-text-color: {{ section.settings.input_text_color }};
      /* Stars */
      --star-size: {{ section.settings.star_size }}px;
      --star-color-empty: {{ section.settings.star_color_empty }};
      --star-color-filled: {{ section.settings.star_color_filled }};

      /* Button */
      --button-bg: {{ section.settings.button_bg_color }};
      --button-color: {{ section.settings.button_text_color }};
      --button-bg-hover: {{ section.settings.button_bg_hover_color }};
      --button-color-hover: {{ section.settings.button_text_hover_color }};
      --button-radius: {{ section.settings.button_border_radius }}px;
      --button-border-color: {{ section.settings.button_border_color }};
      --button-border-width: {{ section.settings.button_border_width }}px;
      --button-font-weight: {{ section.settings.button_font_weight }};
      --button-font-size-m: {{ section.settings.button_font_size_mobile }}px;
      --button-font-size-t: {{ section.settings.button_font_size_tablet }}px;
      --button-font-size-d: {{ section.settings.button_font_size_desktop }}px;
      --button-pad-v: {{ section.settings.button_padding_vertical }}px;
      --button-pad-h: {{ section.settings.button_padding_horizontal }}px;
      --button-full-mobile: {{ section.settings.button_full_width_mobile }};

      /* Divider + bottom bar */
      --divider-color: {{ section.settings.divider_color }};
      --divider-thickness: {{ section.settings.divider_thickness }}px;
      --bottom-bg: {{ section.settings.bottom_bg_color }};
      --bottom-text-color: {{ section.settings.bottom_text_color }};
      --bottom-pad-v: {{ section.settings.bottom_padding_vertical }}px;

      /* Social icons */
      --social-size: {{ section.settings.social_icon_size }}px;
      --social-gap: {{ section.settings.social_icon_gap }}px;
      --social-color: {{ section.settings.social_icon_color }};
      --social-bg: {{ section.settings.social_icon_bg_color }};
      --social-radius: {{ section.settings.social_icon_radius }}px;
      --social-border-color: {{ section.settings.social_icon_border_color }};
      --social-border-width: {{ section.settings.social_icon_border_width }}px;
      --social-hover-color: {{ section.settings.social_icon_hover_color }};
      --social-hover-bg: {{ section.settings.social_icon_bg_hover_color }};
      --social-hover-scale: {{ section.settings.social_icon_hover_scale | divided_by: 100.0 }};
    }

    .section-{{ section.id }}
    -padding {
      padding-top: var(--pad-top-m);
      padding-bottom: var(--pad-bottom-m);
    }

    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: var(--pad-top-t);
        padding-bottom: var(--pad-bottom-t);
      }
    }

    @media screen and (min-width: 990px) {
      .section-{{ section.id }}-padding {
        padding-top: var(--pad-top-d);
        padding-bottom: var(--pad-bottom-d);
      }
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__inner {
      max-width: var(--footer-max-width);
      margin: 0 auto;
      background-color: var(--footer-bg);
      border-radius: var(--footer-inner-radius);
      box-shadow: var(--footer-inner-shadow);
      padding: 1.75rem 1.5rem;
      box-sizing: border-box;
    }

    @media screen and (min-width: 750px) {
      #MinimalFooter-{{ section.id }} .minimal-footer__inner {
        padding: 2.25rem 2rem;
      }
    }

    @media screen and (min-width: 990px) {
      #MinimalFooter-{{ section.id }} .minimal-footer__inner {
        padding: 2.5rem;
      }
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__top {
      display: grid;
      grid-template-columns: 1fr;
      gap: var(--grid-gap-m);
      align-items: flex-start;
    }

    @media screen and (min-width: 750px) {
      #MinimalFooter-{{ section.id }} .minimal-footer__top {
        gap: var(--grid-gap-t);
      }
    }

    @media screen and (min-width: 990px) {
      #MinimalFooter-{{ section.id }} .minimal-footer__top {
        grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
        gap: var(--grid-gap-d);
      }
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__heading
    , #MinimalFooter-{{ section.id }}
    .minimal-footer__form-heading {
      color: var(--heading-color);
      font-weight: var(--heading-weight);
      line-height: var(--heading-lh);
      letter-spacing: var(--heading-letter-spacing);
      font-size: var(--heading-size-m);

    }

    @media screen and (min-width: 750px) {
      #MinimalFooter-{{ section.id }} .minimal-footer__heading
      , #MinimalFooter-{{ section.id }}
      .minimal-footer__form-heading {
        font-size: var(--heading-size-t);
      }
    }

    @media screen and (min-width: 990px) {
      #MinimalFooter-{{ section.id }} .minimal-footer__heading
      , #MinimalFooter-{{ section.id }}
      .minimal-footer__form-heading {
        font-size: var(--heading-size-d);
        margin: 0 0 2.65rem;
      }
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__contact-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.9rem;
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__contact-item {
      display: flex;
      align-items: center;
      gap: 0.8rem;
      color: var(--text-color);
      font-size: var(--text-size-m);
      line-height: var(--text-lh);
    }

    @media screen and (min-width: 750px) {
      #MinimalFooter-{{ section.id }} .minimal-footer__contact-item {
        font-size: var(--text-size-t);
      }
    }

    @media screen and (min-width: 990px) {
      #MinimalFooter-{{ section.id }} .minimal-footer__contact-item {
        font-size: var(--text-size-d);
      }
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__contact-label {
      display: inline-block;
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__contact-link {
      color: var(--text-color);
      text-decoration: none;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s ease
      , opacity 0.2s ease;
      opacity: 0.9;
    }

    #MinimalFooter-{{ section.id }}.minimal-footer__contact-link:hover {
      border-color: var(--text-color);
      opacity: 1;
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__icon {
      width: 3.2rem;
      height: 3.2rem;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border-radius: 999px;
      background: white;
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__icon-svg {
      width: 1.7rem;
      height: 1.7rem;
      fill: rgba(255, 255, 255, 1);
      fill: #1c2228;
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__feedback {
      align-self: stretch;
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__form {
      display: flex;
      flex-direction: column;
      gap: var(--input-gap);
      gap: 13px;
    }

    #MinimalFooter-{{ section.id }}
    .minimal-footer__label {
      display: block;
      margin-bottom: 0.8rem;
      color: var(--text-color);
      opacity: 0.9;
      font-size: var(--text-size-m);
      line-height: var(--text-lh);
    }

    @media screen and (min-width: 750px) {
      #MinimalFooter-{{ section.id }} .minimal-footer__label {
        font-size: var(--text-size-t);
      }
    }

    @media screen and (min-width: 990px) {
      #MinimalFooter-{{ section.id }} .minimal-footer__label {
        font-size: var(--text-size-d);
      }
    }

    #MinimalFooter-{{ section.id }}
