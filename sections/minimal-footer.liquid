<script>
  document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('MinimalFooterForm');
    if (!form) return;
  
    const visibleMessage = document.getElementById('MinimalFooter-message-visible-{{ section.id }}');
    const hiddenMessage = document.getElementById('MinimalFooter-message-hidden-{{ section.id }}');
    const ratingInputs = form.querySelectorAll('input[name="rating"]');
  
    form.addEventListener('submit', function () {
      let selectedRating = '5';
  
      ratingInputs.forEach(function (input) {
        if (input.checked) {
          selectedRating = input.value;
        }
      });
  
      const messageText = visibleMessage ? visibleMessage.value.trim() : '';
  
      hiddenMessage.value =
        'Feedback form submission\n' +
        'Star rating: ' + selectedRating + '/5\n\n' +
        'Message:\n' + messageText;
    });
  });
</script>
