{% comment %}
  Split Section - Two-column layout: image left, text right
  Responsive: stacks on mobile (image above text)
{% endcomment %}

<section
  class="split-section section-{{ section.id }}-padding"
  style="background-color: {{ section.settings.background_color }};"
>
  <div class="split-section__inner page-width">
    <div class="split-section__grid">
      <div class="split-section__media">
        {% if section.settings.image != blank %}
          {{
            section.settings.image
            | image_url: width: 800
            | image_tag: loading: 'lazy', class: 'split-section__image', alt: section.settings.image.alt
            | escape
          }}
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'split-section__placeholder' }}
        {% endif %}
      </div>
      <div class="split-section__content split-section__content--{{ section.settings.text_alignment }}">
        {% if section.settings.heading != blank %}
          <h2 class="split-section__heading" style="color: {{ section.settings.heading_color }};">
            {{ section.settings.heading }}
          </h2>
        {% endif %}
        {% if section.settings.description != blank %}
          <div class="split-section__description" style="color: {{ section.settings.description_color }};">
            {{ section.settings.description }}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% style %}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  .split-section__inner {
    margin: 0 auto;
    padding: 0 1.5rem;
    max-width: var(--page-width, 1200px);
  }

  .split-section__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    align-items: center;
  }

  @media screen and (min-width: 750px) {
    .split-section__grid {
      grid-template-columns: 1fr 1fr;
      gap: 3rem;
    }
  }

  .split-section__media {
    position: relative;
    overflow: hidden;
  }

  .split-section__image,
  .split-section__placeholder {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .split-section__placeholder {
    background-color: rgba(0, 0, 0, 0.05);
    min-height: 200px;
  }

  .split-section__content {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .split-section__content--left {
    text-align: left;
  }

  .split-section__content--center {
    text-align: center;
  }

  .split-section__content--right {
    text-align: right;
  }

  .split-section__heading {
    margin: 0;
    font-size: clamp(1.5rem, 4vw, 2.25rem);
    font-weight: 600;
    line-height: 1.2;
  }

  .split-section__description {
    margin: 0;
    font-size: 1rem;
    line-height: 1.6;
  }

  .split-section__description p {
    margin: 0 0 0.75rem;
  }

  .split-section__description p:last-child {
    margin-bottom: 0;
  }
{% endstyle %}

{% schema %}
{
  "name": "Split section",
  "tag": "section",
  "class": "section",
  "disabled_on": { "groups": ["header", "footer"] },
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Split section heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Add your description text here.</p>"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#333333"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "Split section",
      "category": "Image"
    }
  ]
}
{% endschema %}
