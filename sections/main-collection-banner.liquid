{% comment %}theme-check-disable ImgLazyLoading{% endcomment %}
{{ 'component-collection-hero.css' | asset_url | stylesheet_tag }}

{%- style -%}
        #CollectionBanner-{{ section.id }} {
          margin-top: {{ section.settings.banner_margin_top_desktop }}px;
          margin-bottom: {{ section.settings.banner_margin_bottom_desktop }}px;
        }

        #CollectionBanner-{{ section.id }} .collection-hero__inner {
          padding-top: {{ section.settings.banner_padding_top_desktop }}px;
          padding-bottom: {{ section.settings.banner_padding_bottom_desktop }}px;
        }

        #CollectionBanner-{{ section.id }} .collection-hero__title {
          font-size: {{ section.settings.banner_title_font_size_desktop }}px;
          font-weight: {{ section.settings.banner_title_font_weight_desktop }};
          line-height: {{ section.settings.banner_title_line_height_desktop }};
          color: {{ section.settings.banner_title_color_desktop }};
        }

        #CollectionBanner-{{ section.id }} .collection-hero__description {
          font-size: {{ section.settings.banner_description_font_size_desktop }}px;
          font-weight: {{ section.settings.banner_description_font_weight_desktop }};
          line-height: {{ section.settings.banner_description_line_height_desktop }};
          color: {{ section.settings.banner_description_color_desktop }};
        }
        #CollectionBanner-{{ section.id }} .collection-hero__text-wrapper {
        text-align: {{ section.settings.banner_text_align_desktop }};
      }

        @media screen and (max-width: 989px) {
          #CollectionBanner-{{ section.id }} {
            margin-top: {{ section.settings.banner_margin_top_tablet }}px;
            margin-bottom: {{ section.settings.banner_margin_bottom_tablet }}px;
          }

          #CollectionBanner-{{ section.id }} .collection-hero__inner {
            padding-top: {{ section.settings.banner_padding_top_tablet }}px;
            padding-bottom: {{ section.settings.banner_padding_bottom_tablet }}px;
          }

          #CollectionBanner-{{ section.id }} .collection-hero__title {
            font-size: {{ section.settings.banner_title_font_size_tablet }}px;
            font-weight: {{ section.settings.banner_title_font_weight_tablet }};
            line-height: {{ section.settings.banner_title_line_height_tablet }};
            color: {{ section.settings.banner_title_color_tablet }};
          }

          #CollectionBanner-{{ section.id }} .collection-hero__description {
            font-size: {{ section.settings.banner_description_font_size_tablet }}px;
            font-weight: {{ section.settings.banner_description_font_weight_tablet }};
            line-height: {{ section.settings.banner_description_line_height_tablet }};
            color: {{ section.settings.banner_description_color_tablet }};
          }
          #CollectionBanner-{{ section.id }} .collection-hero__text-wrapper {
      text-align: {{ section.settings.banner_text_align_tablet }};
    }
        }

        @media screen and (max-width: 749px) {
          #CollectionBanner-{{ section.id }} {
            margin-top: {{ section.settings.banner_margin_top_mobile }}px;
            margin-bottom: {{ section.settings.banner_margin_bottom_mobile }}px;
          }

          #CollectionBanner-{{ section.id }} .collection-hero__inner {
            padding-top: {{ section.settings.banner_padding_top_mobile }}px;
            padding-bottom: {{ section.settings.banner_padding_bottom_mobile }}px;
          }

          #CollectionBanner-{{ section.id }} .collection-hero__title {
            font-size: {{ section.settings.banner_title_font_size_mobile }}px;
            font-weight: {{ section.settings.banner_title_font_weight_mobile }};
            line-height: {{ section.settings.banner_title_line_height_mobile }};
            color: {{ section.settings.banner_title_color_mobile }};
          }

          #CollectionBanner-{{ section.id }} .collection-hero__description {
            font-size: {{ section.settings.banner_description_font_size_mobile }}px;
            font-weight: {{ section.settings.banner_description_font_weight_mobile }};
            line-height: {{ section.settings.banner_description_line_height_mobile }};
            color: {{ section.settings.banner_description_color_mobile }};
          }
          #CollectionBanner-{{ section.id }} .collection-hero__text-wrapper {
    text-align: {{ section.settings.banner_text_align_mobile }};
  }
          .collection-hero--with-image .collection-hero__inner {
            padding-bottom: calc({{ settings.media_shadow_vertical_offset | at_least: 0 }}px + 2rem);
          }
        }
{%- endstyle -%}

<div
  id="CollectionBanner-{{ section.id }}"
  class="collection-hero{% if section.settings.show_collection_image and collection.image %} collection-hero--with-image{% endif %} color-{{ section.settings.color_scheme }} gradient"
>
  <div class="collection-hero__inner page-width {% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    <div class="collection-hero__text-wrapper">
      <h1 class="collection-hero__title">
        <span class="visually-hidden">{{ 'sections.collection_template.title' | t }}: </span>
        OUR CLOTHING COLLECTION
      </h1>

      {%- if section.settings.show_collection_description -%}
        <div class="collection-hero__description rte">{{ collection.description }}</div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_collection_image and collection.image -%}
      <div class="collection-hero__image-container media gradient">
        <img
          srcset="
            {%- if collection.image.width >= 165 -%}{{ collection.image | image_url: width: 165 }} 165w,{%- endif -%}
            {%- if collection.image.width >= 360 -%}{{ collection.image | image_url: width: 360 }} 360w,{%- endif -%}
            {%- if collection.image.width >= 535 -%}{{ collection.image | image_url: width: 535 }} 535w,{%- endif -%}
            {%- if collection.image.width >= 750 -%}{{ collection.image | image_url: width: 750 }} 750w,{%- endif -%}
            {%- if collection.image.width >= 1070 -%}{{ collection.image | image_url: width: 1070 }} 1070w,{%- endif -%}
            {%- if collection.image.width >= 1500 -%}{{ collection.image | image_url: width: 1500 }} 1500w,{%- endif -%}
            {{ collection.image | image_url }} {{ collection.image.width }}w
          "
          src="{{ collection.image | image_url: width: 750 }}"
          sizes="(min-width: {{ settings.page_width }}px) {{ settings.page_width | minus: 100 | divided_by: 2 }}px, (min-width: 750px) calc(50vw - 130px), calc(50vw - 55px)"
          alt="{{ collection.image.alt | escape }}"
          width="{{ collection.image.width }}"
          height="{{ collection.image.height }}"
        >
      </div>
    {%- endif -%}
  </div>
</div>

