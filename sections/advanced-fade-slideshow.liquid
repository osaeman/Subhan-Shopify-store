{% comment %}
  Advanced Fade Slideshow - Production-ready Shopify section
  Fade transition, multiple slides, full responsive controls
  Liquid, HTML, CSS, minimal vanilla JS only
{% endcomment %}

<section
  id="AdvancedFadeSlideshow-{{ section.id }}"
  class="advanced-fade-slideshow section-{{ section.id }}-padding"
  role="region"
  aria-roledescription="Slideshow"
  aria-label="{{ section.settings.accessibility_label | escape }}"
>
  <div class="advanced-fade-slideshow__inner" data-slideshow-container>
    {% if section.blocks.size > 0 %}
      <div class="advanced-fade-slideshow__track" data-slideshow-track>
        {% for block in section.blocks %}
          {% if block.type == 'slide' %}
            {% liquid
              assign img_desktop = block.settings.image_desktop | default: block.settings.image
              assign img_tablet = block.settings.image_tablet | default: img_desktop
              assign img_mobile = block.settings.image_mobile | default: img_tablet
              assign img_fallback = img_desktop | default: img_tablet | default: img_mobile
            %}
            <div
              class="advanced-fade-slideshow__slide{% if forloop.first %} is-active{% endif %}"
              data-slide-index="{{ forloop.index0 }}"
              {{ block.shopify_attributes }}
              role="group"
              aria-roledescription="Slide"
              aria-label="{{ forloop.index }} of {{ section.blocks.size }}"
            >
              <div class="advanced-fade-slideshow__media">
                {% if img_fallback != blank %}
                  <picture>
                    {% if img_mobile != blank %}
                      <source media="(max-width: 749px)" srcset="{{ img_mobile | image_url: width: 800 }}">
                    {% endif %}
                    {% if img_tablet != blank %}
                      <source
                        media="(min-width: 750px) and (max-width: 989px)"
                        srcset="{{ img_tablet | image_url: width: 1200 }}"
                      >
                    {% endif %}
                    <img
                      class="advanced-fade-slideshow__image"
                      src="{{ img_fallback | image_url: width: 1600 }}"
                      alt="{{ block.settings.image_alt | escape }}"
                      loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
                      fetchpriority="{% if forloop.first %}high{% else %}low{% endif %}"
                      width="1600"
                      height="{{ 1600 | divided_by: img_fallback.aspect_ratio | round }}"
                    >
                  </picture>
                {% else %}
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'advanced-fade-slideshow__placeholder' }}
                {% endif %}
                {% if block.settings.show_overlay %}
                  <div
                    class="advanced-fade-slideshow__overlay"
                    style="--slide-overlay-color: {{ block.settings.overlay_color }}; --slide-overlay-opacity: {{ block.settings.overlay_opacity | divided_by: 100.0 }};"
                  ></div>
                {% endif %}
              </div>

              <div
                class="advanced-fade-slideshow__content advanced-fade-slideshow__content--h-{{ block.settings.content_position_h_desktop }} advanced-fade-slideshow__content--v-{{ block.settings.content_position_v_desktop }}"
                data-h-d="{{ block.settings.content_position_h_desktop }}"
                data-v-d="{{ block.settings.content_position_v_desktop }}"
                data-h-t="{{ block.settings.content_position_h_tablet }}"
                data-v-t="{{ block.settings.content_position_v_tablet }}"
                data-h-m="{{ block.settings.content_position_h_mobile }}"
                data-v-m="{{ block.settings.content_position_v_mobile }}"
              >
                <div class="advanced-fade-slideshow__content-inner">
                  {% if block.settings.heading != blank %}
                    <h2 class="advanced-fade-slideshow__heading">{{ block.settings.heading }}</h2>
                  {% endif %}
                  {% if block.settings.description != blank %}
                    <div class="advanced-fade-slideshow__description rte">{{ block.settings.description }}</div>
                  {% endif %}
                  {% if block.settings.button_label != blank %}
                    <a href="{{ block.settings.button_link | default: '#' }}" class="advanced-fade-slideshow__button">
                      {{ block.settings.button_label | escape }}
                    </a>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>

      {% if section.blocks.size > 1 %}
        {% if section.settings.show_arrows %}
          <button
            type="button"
            class="advanced-fade-slideshow__arrow advanced-fade-slideshow__arrow--prev"
            aria-label="Previous slide"
            data-slideshow-prev
          >
            <span aria-hidden="true">&#10094;</span>
          </button>
          <button
            type="button"
            class="advanced-fade-slideshow__arrow advanced-fade-slideshow__arrow--next"
            aria-label="Next slide"
            data-slideshow-next
          >
            <span aria-hidden="true">&#10095;</span>
          </button>
        {% endif %}
        {% if section.settings.show_dots %}
          <div class="advanced-fade-slideshow__dots" role="tablist" aria-label="Slide navigation">
            {% for block in section.blocks %}
              {% if block.type == 'slide' %}
                <button
                  type="button"
                  class="advanced-fade-slideshow__dot{% if forloop.first %} is-active{% endif %}"
                  role="tab"
                  aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
                  aria-label="Go to slide {{ forloop.index }}"
                  data-slideshow-dot="{{ forloop.index0 }}"
                ></button>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}
      {% endif %}
    {% else %}
      <div class="advanced-fade-slideshow__empty">
        <p>Add slides to this slideshow.</p>
      </div>
    {% endif %}
  </div>
</section>

{% style %}
  #AdvancedFadeSlideshow-{{ section.id }} {
    --section-height-d: {{ section.settings.section_height_desktop }}px;
    --section-height-t: {{ section.settings.section_height_tablet }}px;
    --section-height-m: {{ section.settings.section_height_mobile }}px;
    --content-max-width: {{ section.settings.content_max_width }}px;
    --content-gap-d: {{ section.settings.content_gap_desktop }}px;
    --content-gap-t: {{ section.settings.content_gap_tablet }}px;
    --content-gap-m: {{ section.settings.content_gap_mobile }}px;
    --heading-color: {{ section.settings.heading_color }};
    --heading-weight: {{ section.settings.heading_weight }};
    --heading-size-d: {{ section.settings.heading_size_desktop }}px;
    --heading-size-t: {{ section.settings.heading_size_tablet }}px;
    --heading-size-m: {{ section.settings.heading_size_mobile }}px;
    --heading-lh-d: {{ section.settings.heading_line_height_desktop | divided_by: 100.0 }};
    --heading-lh-t: {{ section.settings.heading_line_height_tablet | divided_by: 100.0 }};
    --heading-lh-m: {{ section.settings.heading_line_height_mobile | divided_by: 100.0 }};
    --heading-mt-m: {{ section.settings.heading_margin_top_mobile }}px;
    --desc-color: {{ section.settings.description_color }};
    --desc-weight: {{ section.settings.description_weight }};
    --desc-size-d: {{ section.settings.description_size_desktop }}px;
    --desc-size-t: {{ section.settings.description_size_tablet }}px;
    --desc-size-m: {{ section.settings.description_size_mobile }}px;
    --desc-lh-d: {{ section.settings.description_line_height_desktop | divided_by: 100.0 }};
    --desc-lh-t: {{ section.settings.description_line_height_tablet | divided_by: 100.0 }};
    --desc-lh-m: {{ section.settings.description_line_height_mobile | divided_by: 100.0 }};
    --desc-mt-d: {{ section.settings.description_margin_top_desktop }}px;
    --desc-mb-d: {{ section.settings.description_margin_bottom_desktop }}px;
    --desc-mt-t: {{ section.settings.description_margin_top_tablet }}px;
    --desc-mb-t: {{ section.settings.description_margin_bottom_tablet }}px;
    --desc-mt-m: {{ section.settings.description_margin_top_mobile }}px;
    --desc-mb-m: {{ section.settings.description_margin_bottom_mobile }}px;
    --btn-color: {{ section.settings.button_text_color }};
    --btn-bg: {{ section.settings.button_bg_color }};
    --btn-hover-color: {{ section.settings.button_hover_text_color }};
    --btn-hover-bg: {{ section.settings.button_hover_bg_color }};
    --btn-border: {{ section.settings.button_border_color }};
    --btn-border-w: {{ section.settings.button_border_width }}px;
    --btn-radius: {{ section.settings.button_border_radius }}px;
    --btn-weight: {{ section.settings.button_font_weight }};
    --btn-size-d: {{ section.settings.button_font_size_desktop }}px;
    --btn-size-t: {{ section.settings.button_font_size_tablet }}px;
    --btn-size-m: {{ section.settings.button_font_size_mobile }}px;
    --btn-pad-v-d: {{ section.settings.button_padding_vertical_desktop }}px;
    --btn-pad-h-d: {{ section.settings.button_padding_horizontal_desktop }}px;
    --btn-pad-v-t: {{ section.settings.button_padding_vertical_tablet }}px;
    --btn-pad-h-t: {{ section.settings.button_padding_horizontal_tablet }}px;
    --btn-pad-v-m: {{ section.settings.button_padding_vertical_mobile }}px;
    --btn-pad-h-m: {{ section.settings.button_padding_horizontal_mobile }}px;
    --overlay-color: {{ section.settings.overlay_color }};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --fade-duration: {{ section.settings.fade_duration }}ms;
  }

  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.section_padding_top_mobile }}px;
    padding-bottom: {{ section.settings.section_padding_bottom_mobile }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.section_padding_top_tablet }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_tablet }}px;
    }
  }
  @media screen and (min-width: 990px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.section_padding_top_desktop }}px;
      padding-bottom: {{ section.settings.section_padding_bottom_desktop }}px;
    }
  }

  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__inner {
    position: relative;
    width: 100%;
    overflow: hidden;
    background-color: {{ section.settings.section_bg_color }};
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__track {
    position: relative;
    width: 100%;
    min-height: var(--section-height-m);
  }
  @media screen and (min-width: 750px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__track { min-height: var(--section-height-t); }
  }
  @media screen and (min-width: 990px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__track { min-height: var(--section-height-d); }
  }

  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: opacity var(--fade-duration) ease-in-out,
    visibility 0s linear var(--fade-duration);
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__slide.is-active {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transition-delay: 0s, 0s;
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__media { position: absolute; inset: 0; }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__image,
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__placeholder {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center center;
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__placeholder { background-color: rgba(0,0,0,0.05); }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__overlay {
    position: absolute;
    inset: 0;
    background-color: var(--slide-overlay-color);
    opacity: var(--slide-overlay-opacity);
    pointer-events: none;
  }

  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content {
    position: relative;
    z-index: 2;
    display: flex;
    height: 100%;
    padding: 1.5rem;
    box-sizing: border-box;
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content-inner {
    max-width: var(--content-max-width);
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: var(--content-gap-m);
  }
  @media screen and (min-width: 750px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content-inner { gap: var(--content-gap-t); }
  }
  @media screen and (min-width: 990px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content-inner { gap: var(--content-gap-d); }
  }

  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__heading {
    margin: 0;
    color: var(--heading-color);
    font-weight: var(--heading-weight);
    font-size: var(--heading-size-m);
    line-height: var(--heading-lh-m);
    text-align: {{ section.settings.text_align_mobile }};
  }
  @media screen and (min-width: 750px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__heading {
      font-size: var(--heading-size-t);
      line-height: var(--heading-lh-t);
      text-align: {{ section.settings.text_align_tablet }};
    }
  }
  @media screen and (min-width: 990px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__heading {
      margin: var(--heading-mt-d) 0 0 0;
      font-size: var(--heading-size-d);
      line-height: var(--heading-lh-d);
      text-align: {{ section.settings.text_align_desktop }};
    }
  }

  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__description {
    margin: var(--desc-mt-m) 0 var(--desc-mb-m);
    color: var(--desc-color);
    font-weight: var(--desc-weight);
    font-size: var(--desc-size-m);
    line-height: var(--desc-lh-m);
    text-align: {{ section.settings.text_align_mobile }};
  }
  @media screen and (min-width: 750px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__description {
      margin: var(--desc-mt-t) 0 var(--desc-mb-t);
      font-size: var(--desc-size-t);
      line-height: var(--desc-lh-t);
      text-align: {{ section.settings.text_align_tablet }};
    }
  }
  @media screen and (min-width: 990px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__description {
      margin: var(--desc-mt-d) 0 var(--desc-mb-d);
      font-size: var(--desc-size-d);
      line-height: var(--desc-lh-d);
      text-align: {{ section.settings.text_align_desktop }};
    }
  }

  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: var(--btn-pad-v-m) var(--btn-pad-h-m);
    color: var(--btn-color);
    background-color: var(--btn-bg);
    border: var(--btn-border-w) solid var(--btn-border);
    border-radius: var(--btn-radius);
    font-weight: var(--btn-weight);
    font-size: var(--btn-size-m);
    text-decoration: none;
    transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease;
    align-self: flex-start;
  }
  @media screen and (min-width: 750px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__button {
      padding: var(--btn-pad-v-t) var(--btn-pad-h-t);
      font-size: var(--btn-size-t);
    }
  }
  @media screen and (min-width: 990px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__button {
      padding: var(--btn-pad-v-d) var(--btn-pad-h-d);
      font-size: var(--btn-size-d);
    }
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__button:hover {
    color: var(--btn-hover-color);
    background-color: var(--btn-hover-bg);
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__button:focus-visible {
    outline: 2px solid currentColor;
    outline-offset: 2px;
  }

  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content--h-left { justify-content: flex-start; }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content--h-center { justify-content: center; }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content--h-right { justify-content: flex-end; }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content--v-top { align-items: flex-start; }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content--v-middle { align-items: center; }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content--v-bottom { align-items: flex-end; }

  @media screen and (max-width: 749px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-m="left"] { justify-content: flex-start; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-m="center"] { justify-content: center; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-m="right"] { justify-content: flex-end; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-v-m="top"] { align-items: flex-start; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-v-m="middle"] { align-items: center; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-v-m="bottom"] { align-items: flex-end; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-m="center"] .advanced-fade-slideshow__button,
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-m="right"] .advanced-fade-slideshow__button { align-self: center; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-m="right"] .advanced-fade-slideshow__button { align-self: flex-end; }
  }
  @media screen and (min-width: 750px) and (max-width: 989px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-t="left"] { justify-content: flex-start; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-t="center"] { justify-content: center; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-t="right"] { justify-content: flex-end; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-v-t="top"] { align-items: flex-start; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-v-t="middle"] { align-items: center; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-v-t="bottom"] { align-items: flex-end; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-t="center"] .advanced-fade-slideshow__button,
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-t="right"] .advanced-fade-slideshow__button { align-self: center; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-t="right"] .advanced-fade-slideshow__button { align-self: flex-end; }
  }
  @media screen and (min-width: 990px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-d="left"] { justify-content: flex-start; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-d="center"] { justify-content: center; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-d="right"] { justify-content: flex-end; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-v-d="top"] { align-items: flex-start; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-v-d="middle"] { align-items: center; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-v-d="bottom"] { align-items: flex-end; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-d="center"] .advanced-fade-slideshow__button,
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-d="right"] .advanced-fade-slideshow__button { align-self: center; }
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__content[data-h-d="right"] .advanced-fade-slideshow__button { align-self: flex-end; }
  }

  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 44px;
    height: 44px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(0,0,0,0.5);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease;
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__arrow:hover { background: rgba(0,0,0,0.7); }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__arrow--prev { left: 1rem; }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__arrow--next { right: 1rem; }
  @media screen and (max-width: 749px) {
    #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__arrow { width: 36px; height: 36px; }
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__dots {
    position: absolute;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 0.5rem;
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__dot {
    width: 10px;
    height: 10px;
    padding: 0;
    border: none;
    border-radius: 50%;
    background: rgba(255,255,255,0.5);
    cursor: pointer;
    transition: background 0.2s ease;
  }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__dot.is-active { background: #fff; }
  #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__empty {
    padding: 4rem 1.5rem;
    text-align: center;
    min-height: 300px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
{% endstyle %}

{% for block in section.blocks %}
  {% if block.type == 'slide' %}
    <style>
      #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__slide[data-slide-index="{{ forloop.index0 }}"] .advanced-fade-slideshow__image {
        object-fit: {{ block.settings.image_object_fit_mobile }};
        object-position: {{ block.settings.image_object_position_mobile }};
      }
      @media screen and (min-width: 750px) {
        #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__slide[data-slide-index="{{ forloop.index0 }}"] .advanced-fade-slideshow__image {
          object-fit: {{ block.settings.image_object_fit_tablet }};
          object-position: {{ block.settings.image_object_position_tablet }};
        }
      }
      @media screen and (min-width: 990px) {
        #AdvancedFadeSlideshow-{{ section.id }} .advanced-fade-slideshow__slide[data-slide-index="{{ forloop.index0 }}"] .advanced-fade-slideshow__image {
          object-fit: {{ block.settings.image_object_fit_desktop }};
          object-position: {{ block.settings.image_object_position_desktop }};
        }
      }
    </style>
  {% endif %}
{% endfor %}

<script>
  (function() {
    var section = document.getElementById('AdvancedFadeSlideshow-{{ section.id }}');
    if (!section) return;
    var slides = section.querySelectorAll('.advanced-fade-slideshow__slide');
    var dots = section.querySelectorAll('[data-slideshow-dot]');
    var prevBtn = section.querySelector('[data-slideshow-prev]');
    var nextBtn = section.querySelector('[data-slideshow-next]');
    var autoplay = {{ section.settings.autoplay | json }};
    var speed = {{ section.settings.autoplay_speed | times: 1000 }};
    var current = 0;
    var timer = null;
    function goTo(i) {
      if (!slides.length) return;
      current = (i + slides.length) % slides.length;
      slides.forEach(function(s, idx) { s.classList.toggle('is-active', idx === current); });
      dots.forEach(function(d, idx) {
        d.classList.toggle('is-active', idx === current);
        d.setAttribute('aria-selected', idx === current ? 'true' : 'false');
      });
    }
    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }
    function startAutoplay() {
      if (!autoplay || slides.length < 2) return;
      stopAutoplay();
      timer = setInterval(next, speed);
    }
    function stopAutoplay() {
      if (timer) { clearInterval(timer); timer = null; }
    }
    if (prevBtn) prevBtn.addEventListener('click', function() { stopAutoplay(); prev(); startAutoplay(); });
    if (nextBtn) nextBtn.addEventListener('click', function() { stopAutoplay(); next(); startAutoplay(); });
    dots.forEach(function(d, i) {
      d.addEventListener('click', function() { stopAutoplay(); goTo(i); startAutoplay(); });
    });
    goTo(0);
    startAutoplay();
  })();
</script>

