<product-info
  id="MainProduct-{{ section.id }}"
  class="section-{{ section.id }}-padding gradient color-{{ section.settings.color_scheme }}"
  data-section="{{ section.id }}"
  data-product-id="{{ product.id }}"
  data-update-url="true"
  data-url="{{ product.url }}"
  {% if section.settings.image_zoom == 'hover' %}
    data-zoom-on-hover
  {% endif %}
>
  {{ 'section-main-product.css' | asset_url | stylesheet_tag }}
  {{ 'component-accordion.css' | asset_url | stylesheet_tag }}
  {{ 'component-price.css' | asset_url | stylesheet_tag }}
  {{ 'component-slider.css' | asset_url | stylesheet_tag }}
  {{ 'component-rating.css' | asset_url | stylesheet_tag }}
  {{ 'component-deferred-media.css' | asset_url | stylesheet_tag }}

  {% unless product.has_only_default_variant %}
    {{ 'component-product-variant-picker.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch-input.css' | asset_url | stylesheet_tag }}
    {{ 'component-swatch.css' | asset_url | stylesheet_tag }}
  {% endunless %}

  {%- if product.quantity_price_breaks_configured? -%}
    {{ 'component-volume-pricing.css' | asset_url | stylesheet_tag }}
  {%- endif -%}

  {%- liquid
    assign info_column_width_tablet = 100 | minus: section.settings.media_column_width_tablet
    assign info_column_width_desktop = 100 | minus: section.settings.media_column_width_desktop
  -%}

  {%- style -%}
        /* =========================
           Main image hover zoom
        ========================= */
        .section-{{ section.id }}-padding .custom-product-gallery__main-item {
          cursor: zoom-in;
        }

        .section-{{ section.id }}-padding .custom-product-gallery__main-item img {
          transition: transform 0.18s ease-out, transform-origin 0.08s linear;
          will-change: transform;
        }

        @media (hover: hover) and (pointer: fine) {
          .section-{{ section.id }}-padding .custom-product-gallery__main-item.is-zooming img {
            transform: scale(1.6);
          }
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__backdrop {
          position: absolute;
          inset: 0;
          background: rgba(17, 17, 17, 0.72);
          backdrop-filter: blur(18px);
          -webkit-backdrop-filter: blur(18px);
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__dialog {
          position: relative;
          z-index: 2;
          width: min(97vw, 1680px);
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__track {
          display: flex;
          height: 100%;
          transition: transform 0.35s ease;
          will-change: transform;
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__viewport {
          position: relative;
          overflow: hidden;
          width: 100%;
          height: min(95vh, calc(100vh - 24px));
          padding: 12px;
          border-radius: 22px;
          background: #ffffff;
          box-shadow: 0 30px 100px rgba(0, 0, 0, 0.34);
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__slide {
          min-width: 100%;
          height: 100%;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__slide-image {
          display: block;
          width: auto !important;
          height: auto !important;
          max-width: 100% !important;
          max-height: 100% !important;
          object-fit: contain !important;
          object-position: center;
          margin: auto;
          border-radius: 16px;
          background: #ffffff;
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__nav,
        .section-{{ section.id }}-padding .custom-product-zoom-overlay__close {
          position: absolute;
          z-index: 4;
          border: none;
          border-radius: 999px;
          background: rgba(17, 17, 17, 0.78);
          color: #ffffff;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          cursor: pointer;
          box-shadow: 0 12px 30px rgba(0, 0, 0, 0.24);
          transition: transform 0.25s ease, background-color 0.25s ease, opacity 0.25s ease;
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__nav {
          top: 50%;
          width: 48px;
          height: 48px;
          transform: translateY(-50%);
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__nav--prev {
          left: 18px;
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__nav--next {
          right: 18px;
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__close {
          top: 18px;
          right: 18px;
          width: 48px;
          height: 48px;
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__nav:hover {
          transform: translateY(-50%) scale(1.04);
          background: rgba(17, 17, 17, 0.92);
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__close:hover {
          transform: scale(1.04);
          background: rgba(17, 17, 17, 0.92);
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__nav[disabled] {
          opacity: 0.34;
          cursor: default;
          transform: translateY(-50%);
        }

        .section-{{ section.id }}-padding .custom-product-zoom-overlay__counter {
          position: absolute;
          left: 50%;
          bottom: 16px;
          transform: translateX(-50%);
          z-index: 4;
          padding: 9px 14px;
          border-radius: 999px;
          background: rgba(17, 17, 17, 0.82);
          color: #ffffff;
          font-size: 13px;
          line-height: 1;
          letter-spacing: 0.04em;
        }

        /* =========================
           Description
        ========================= */
        .section-{{ section.id }}-padding .product__description.rte {
          font-size: {{ section.settings.description_text_size_mobile }}px;
          line-height: {{ section.settings.description_text_line_height_mobile | divided_by: 10.0 }};
          text-align: {{ section.settings.description_text_alignment }};
        }

        .section-{{ section.id }}-padding .product__description.rte p,
        .section-{{ section.id }}-padding .product__description.rte li {
          font-size: inherit;
          line-height: inherit;
        }

        .section-{{ section.id }}-padding .product__description.rte p {
          margin: 0 0 {{ section.settings.description_paragraph_spacing_mobile }}px;
        }

        .section-{{ section.id }}-padding .product__description.rte ul,
        .section-{{ section.id }}-padding .product__description.rte ol {
          margin: 0 0 {{ section.settings.description_list_bottom_spacing_mobile }}px;
          padding-left: {{ section.settings.description_list_padding_left_mobile }}px;
        }

        .section-{{ section.id }}-padding .product__description.rte li + li {
          margin-top: {{ section.settings.description_list_spacing_mobile }}px;
        }

        .section-{{ section.id }}-padding .product__description.rte li > p {
          display: inline;
          margin: 0;
        }

        .section-{{ section.id }}-padding .product__description.rte li > p:first-child:last-child {
          display: inline;
        }

        .section-{{ section.id }}-padding .product__description.rte li::marker {
          font-size: 0.9em;
        }

        .section-{{ section.id }}-padding .product__description.rte li {
          margin: 0;
        }

        /* =========================
           Section spacing / background
        ========================= */
        .section-{{ section.id }}-padding {
          padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
          padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
          background: {{ section.settings.section_background_color }};
        }

        /* =========================
           Product layout
        ========================= */
        .section-{{ section.id }}-padding .product {
          column-gap: {{ section.settings.product_grid_gap_mobile }}px;
          row-gap: {{ section.settings.product_grid_gap_mobile }}px;
        }

        .section-{{ section.id }}-padding .product__info-container {
          display: block;
        }

        .section-{{ section.id }}-padding .product__title,
        .section-{{ section.id }}-padding .product__pricing-row,
        .section-{{ section.id }}-padding .product__shipping-bar,
        .section-{{ section.id }}-padding .product-form__input,
        .section-{{ section.id }}-padding .product-form__buttons,
        .section-{{ section.id }}-padding .product__description-block {
          width: 100%;
        }

        /* =========================
           Product title / price
        ========================= */
        .section-{{ section.id }}-padding .product__title h1,
        .section-{{ section.id }}-padding .product__title .h1 {
          margin: 0;
          font-size: {{ section.settings.product_title_size_mobile }}px;
          font-weight: {{ section.settings.product_title_weight }};
          line-height: {{ section.settings.product_title_line_height_mobile | divided_by: 10.0 }};
          color: {{ section.settings.product_title_color }};
        }

        .section-{{ section.id }}-padding .product__variant-tag {
          margin: 0;
          margin-top: {{ section.settings.variant_tag_margin_top_mobile }}px;
          font-size: {{ section.settings.variant_tag_size }}px;
          font-weight: {{ section.settings.variant_tag_weight }};
          line-height: 1.4;
          letter-spacing: 0.04em;
          text-transform: uppercase;
          color: {{ section.settings.variant_tag_color }};
        }

        .section-{{ section.id }}-padding .product__pricing-row {
          display: flex;
          align-items: center;
          flex-wrap: wrap;
          gap: 10px;
          margin-top: 0;
        }

        .section-{{ section.id }}-padding .product__price-current {
          margin: 0;
          font-size: {{ section.settings.price_size }}px;
          font-weight: {{ section.settings.price_weight }};
          line-height: 1.2;
          color: {{ section.settings.price_color }};
        }

        .section-{{ section.id }}-padding .product__price-compare {
          margin: 0;
          font-size: {{ section.settings.compare_price_size }}px;
          font-weight: 500;
          line-height: 1.2;
          text-decoration: line-through;
          opacity: 0.8;
          color: {{ section.settings.compare_price_color }};
        }

        .section-{{ section.id }}-padding .product__discount-text {
          margin: 0;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          padding: {{ section.settings.discount_text_padding_vertical }}px {{ section.settings.discount_text_padding_horizontal }}px;
          border-radius: 999px;
          background: {{ section.settings.discount_text_bg }};
          font-size: {{ section.settings.discount_text_size }}px;
          font-weight: {{ section.settings.discount_text_weight }};
          line-height: 1.2;
          letter-spacing: 0.03em;
          text-transform: uppercase;
          color: {{ section.settings.discount_text_color }};
        }

        .section-{{ section.id }}-padding .product__shipping-bar {
          margin-top: {{ section.settings.shipping_bar_margin_top_mobile }}px;
          padding: {{ section.settings.shipping_bar_padding_vertical_mobile }}px {{ section.settings.shipping_bar_padding_horizontal_mobile }}px;
          border-radius: {{ section.settings.shipping_bar_radius }}px;
          background: {{ section.settings.shipping_bar_bg }};
          color: {{ section.settings.shipping_bar_text_color }};
          font-size: {{ section.settings.shipping_bar_font_size_mobile }}px;
          line-height: 1.5;
        }

        .section-{{ section.id }}-padding .product__shipping-bar a {
          color: inherit;
          text-decoration: underline;
          text-underline-offset: 2px;
        }

        /* =========================
           Description block
        ========================= */
        .section-{{ section.id }}-padding .product__description-heading {
          margin: 0;
          font-size: {{ section.settings.description_heading_size }}px;
          font-weight: {{ section.settings.description_heading_weight }};
          line-height: 1.25;
          color: {{ section.settings.description_heading_color }};
          margin-bottom: 14px;
        }

        .section-{{ section.id }}-padding .product__description-block {
          margin-top: {{ section.settings.description_margin_top_mobile }}px;
        }

        .section-{{ section.id }}-padding .product__description.rte,
        .section-{{ section.id }}-padding .product__description.rte > * {
          margin-top: 0;
        }

        .section-{{ section.id }}-padding .product__description.rte > *:last-child {
          margin-bottom: 0;
        }

        .section-{{ section.id }}-padding .volume-pricing-note,
        .section-{{ section.id }}-padding .installment {
          margin-top: 0;
          margin-bottom: 0;
        }

        /* =========================
           Buttons
        ========================= */
        .section-{{ section.id }}-padding .product-form__input {
          margin-top: 0;
        }

        .section-{{ section.id }}-padding .product-form__buttons {
          display: flex;
          flex-wrap: wrap;
          align-items: stretch;
          gap: {{ section.settings.button_gap_mobile }}px;
          margin-top: 0;
        }

        .section-{{ section.id }}-padding .product-form__buttons .product-form__submit,
        .section-{{ section.id }}-padding .product-form__buttons .shopify-payment-button {
          min-width: 0;
        }

        .section-{{ section.id }}-padding .product-form__buttons.product-form__buttons--multiple .product-form__submit,
        .section-{{ section.id }}-padding .product-form__buttons.product-form__buttons--multiple .shopify-payment-button {
          flex: 1 1 calc(50% - ({{ section.settings.button_gap_mobile }}px / 2));
          max-width: calc(50% - ({{ section.settings.button_gap_mobile }}px / 2));
          width: calc(50% - ({{ section.settings.button_gap_mobile }}px / 2)) !important;
        }

        .section-{{ section.id }}-padding .product-form__buttons:not(.product-form__buttons--multiple) .product-form__submit,
        .section-{{ section.id }}-padding .product-form__buttons:not(.product-form__buttons--multiple) .shopify-payment-button {
          flex: 1 1 100%;
          max-width: 100%;
          width: 100% !important;
        }

        .section-{{ section.id }}-padding .product-form__buttons .shopify-payment-button,
        .section-{{ section.id }}-padding .product-form__buttons .shopify-payment-button__button,
        .section-{{ section.id }}-padding .product-form__buttons .shopify-payment-button__button--unbranded {
          width: 100% !important;
          margin-top: 0 !important;
        }

        .section-{{ section.id }}-padding .product-form__buttons .button,
        .section-{{ section.id }}-padding .shopify-payment-button__button,
        .section-{{ section.id }}-padding .shopify-payment-button__button--unbranded {
          min-height: auto !important;
          padding-top: {{ section.settings.button_padding_vertical }}px !important;
          padding-bottom: {{ section.settings.button_padding_vertical }}px !important;
          border-radius: {{ section.settings.button_radius }}px !important;
          font-size: {{ section.settings.button_font_size }}px !important;
          font-weight: {{ section.settings.button_font_weight }} !important;
          text-transform: {{ section.settings.button_text_transform }} !important;
          outline: none !important;
          box-shadow: none !important;
          transition:
            background-color 0.25s ease,
            color 0.25s ease,
            border-color 0.25s ease,
            transform 0.25s ease;
        }

        .section-{{ section.id }}-padding .product-form__buttons .button:focus,
        .section-{{ section.id }}-padding .product-form__buttons .button:focus-visible,
        .section-{{ section.id }}-padding .product-form__buttons .shopify-payment-button__button:focus,
        .section-{{ section.id }}-padding .product-form__buttons .shopify-payment-button__button:focus-visible,
        .section-{{ section.id }}-padding .product-form__buttons .shopify-payment-button__button--unbranded:focus,
        .section-{{ section.id }}-padding .product-form__buttons .shopify-payment-button__button--unbranded:focus-visible {
          outline: none !important;
          box-shadow: none !important;
        }

        .section-{{ section.id }}-padding .product-form__submit {
          background: {{ section.settings.add_to_cart_bg }} !important;
          color: {{ section.settings.add_to_cart_text }} !important;
          border: {{ section.settings.add_to_cart_border_width }}px solid {{ section.settings.add_to_cart_border_color }} !important;
          box-shadow: none !important;
        }

        .section-{{ section.id }}-padding .product-form__submit:hover {
          background: {{ section.settings.add_to_cart_bg_hover }} !important;
          transform: translateY(-1px);
        }

        .section-{{ section.id }}-padding .shopify-payment-button {
          margin-top: 0 !important;
        }

        .section-{{ section.id }}-padding .shopify-payment-button__button,
        .section-{{ section.id }}-padding .shopify-payment-button__button--unbranded {
          background: {{ section.settings.buy_now_bg }} !important;
          color: {{ section.settings.buy_now_text }} !important;
          border: {{ section.settings.buy_now_border_width }}px solid {{ section.settings.buy_now_border_color }} !important;
          box-shadow: none !important;
        }

        .section-{{ section.id }}-padding .shopify-payment-button__button:hover,
        .section-{{ section.id }}-padding .shopify-payment-button__button--unbranded:hover {
          background: {{ section.settings.buy_now_bg_hover }} !important;
          transform: translateY(-1px);
        }

        /* =========================
           Quantity
        ========================= */
        .section-{{ section.id }}-padding .product-form__quantity {
          display: flex;
          flex-direction: column;
          align-items: flex-start;
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__label {
          margin-bottom: {{ section.settings.quantity_label_spacing_bottom }}px;
          padding-bottom: 0;
          font-size: {{ section.settings.quantity_label_size }}px;
          font-weight: {{ section.settings.quantity_label_weight }};
          color: {{ section.settings.quantity_label_color }};
        }

        .section-{{ section.id }}-padding .product-form__quantity .price-per-item__container {
          width: 100%;
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity {
          width: min({{ section.settings.quantity_box_width }}px, 100%);
          min-height: {{ section.settings.quantity_box_height }}px;
          display: grid;
          grid-template-columns: 48px 1fr 48px;
          align-items: center;
          overflow: hidden;
          border: 1px solid {{ section.settings.quantity_box_border_color }};
          border-radius: {{ section.settings.quantity_box_radius }}px;
          background: {{ section.settings.quantity_box_bg }};
          box-shadow: none;
          outline: none;
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity:focus-within {
          outline: none;
          box-shadow: none;
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__button {
          width: 48px;
          min-width: 48px;
          height: 100%;
          display: inline-flex;
          align-items: center;
          justify-content: center;
          background: {{ section.settings.quantity_button_bg }};
          border: none;
          color: {{ section.settings.quantity_button_color }};
          outline: none;
          box-shadow: none;
          transition: background-color 0.25s ease, transform 0.25s ease;
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__button:first-child {
          border-right: 1px solid {{ section.settings.quantity_box_border_color }};
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__button:last-child {
          border-left: 1px solid {{ section.settings.quantity_box_border_color }};
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__button:hover {
          filter: brightness(0.96);
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__button:focus,
        .section-{{ section.id }}-padding .product-form__quantity .quantity__button:focus-visible {
          outline: none;
          box-shadow: none;
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__button .svg-wrapper,
        .section-{{ section.id }}-padding .product-form__quantity .quantity__button svg {
          width: 16px;
          height: 16px;
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__input {
          height: 100%;
          padding: 0 8px;
          border: none;
          background: {{ section.settings.quantity_input_bg }};
          box-shadow: none;
          outline: none;
          text-align: center;
          font-size: 16px;
          font-weight: 600;
          color: {{ section.settings.quantity_input_color }};
          appearance: textfield;
          -moz-appearance: textfield;
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__input:focus,
        .section-{{ section.id }}-padding .product-form__quantity .quantity__input:focus-visible {
          outline: none;
          box-shadow: none;
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__input::-webkit-outer-spin-button,
        .section-{{ section.id }}-padding .product-form__quantity .quantity__input::-webkit-inner-spin-button {
          -webkit-appearance: none;
          margin: 0;
        }

        .section-{{ section.id }}-padding .product-form__quantity .quantity__rules {
          margin-top: 0;
        }

        .section-{{ section.id }}-padding #Quantity-Form-{{ section.id }},
        .section-{{ section.id }}-padding .product-form__input.product-form__quantity {
          margin-top: {{ section.settings.quantity_margin_top_mobile }}px !important;
          margin-bottom: 0 !important;
          padding-top: 0 !important;
          padding-bottom: 0 !important;
        }

        .section-{{ section.id }}-padding #Quantity-Form-{{ section.id }} .price-per-item__container,
        .section-{{ section.id }}-padding #Quantity-Form-{{ section.id }} .quantity__rules,
        .section-{{ section.id }}-padding #Quantity-Form-{{ section.id }} price-per-item,
        .section-{{ section.id }}-padding #Quantity-Form-{{ section.id }} .price-per-item {
          margin-top: 0 !important;
          margin-bottom: 0 !important;
          padding-top: 0 !important;
          padding-bottom: 0 !important;
        }

        /* =========================
           Gallery - main image
        ========================= */
        .section-{{ section.id }}-padding .custom-product-gallery__viewer {
          position: relative;
        }

        .section-{{ section.id }}-padding .custom-product-gallery__main-list {
          position: relative;
          display: block !important;
          width: 100%;
          height: {{ section.settings.main_image_height_mobile }}px;
          min-height: 0;
          margin: 0;
          padding: 0;
          overflow: hidden;
          border-radius: {{ section.settings.main_image_radius }}px;
        }

        .section-{{ section.id }}-padding .custom-product-gallery__main-item {
          position: absolute !important;
          inset: 0;
          z-index: 0;
          width: 100%;
          margin: 0 !important;
          display: block !important;
          overflow: hidden;
          border-radius: {{ section.settings.main_image_radius }}px;
          border: none !important;
          box-shadow: none !important;
          opacity: 0;
          visibility: hidden;
          pointer-events: none;
          transform: scale(1.02);
          will-change: opacity, transform;
          transition:
            opacity 0.55s ease,
            transform 0.45s ease,
            visibility 0s linear 0.45s;
        }

        .section-{{ section.id }}-padding .custom-product-gallery__main-item.is-active {
          z-index: 2;
          opacity: 1;
          visibility: visible;
          pointer-events: auto;
          transform: scale(1);
          transition:
            opacity 0.55s ease,
            transform 0.45s ease,
            visibility 0s linear 0s;
        }

        .section-{{ section.id }}-padding .custom-product-gallery__main-item .product-media-container,
        .section-{{ section.id }}-padding .custom-product-gallery__main-item .media {
          width: 100%;
          height: {{ section.settings.main_image_height_mobile }}px !important;
          border-radius: {{ section.settings.main_image_radius }}px;
          overflow: hidden;
          border: none !important;
          box-shadow: none !important;
        }

        .section-{{ section.id }}-padding .custom-product-gallery__main-item img {
          width: 100%;
          height: 100% !important;
          display: block;
          object-fit: {{ section.settings.main_image_object_fit }};
          object-position: {{ section.settings.main_image_object_position }};
          border-radius: {{ section.settings.main_image_radius }}px;
        }

        .section-{{ section.id }}-padding .custom-product-gallery__viewer .slider {
          scroll-snap-type: none !important;
        }

        .section-{{ section.id }}-padding .custom-product-gallery__viewer .slider__slide {
          scroll-snap-align: unset !important;
        }

        /* =========================
           Gallery - thumbnails
        ========================= */
        .section-{{ section.id }}-padding .custom-product-gallery__thumb-slider {
          width: 100%;
          margin-top: 10px;
          padding-left: 0 !important;
          padding-right: 0 !important;
        }

        .section-{{ section.id }}-padding .custom-product-gallery__thumb-list {
          display: flex !important;
          flex-wrap: nowrap;
          gap: 10px;
          width: 100%;
          margin: 0;
          padding: 0 0 8px;
          overflow-x: auto;
