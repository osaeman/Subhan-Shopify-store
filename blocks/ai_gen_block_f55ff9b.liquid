{% doc %}
  @prompt
    I want you to design a section similar to the featured product section of Shopify, but obviously with a modern, sleek, and e-commerce-oriented beautiful design. The section will have a heading first, and then it will have a grid of 4 (for the laptop version), and every grid hosts a product card. The card has an image of the product, then the title of the product, then a small subtle tag (for example, like "Unstitched | New Arrival"), and then the price of the product (also the discounted price, other, or cut price, or compare price option, whatever you call it—designed in a very minimalist and subtle manner). Then the product star rating or rating in a unique way is designed, and a beautiful, homogenous button is created. The overall design of the section must be a sleek, modern, mimialist and elegant e-commerce UI. Also, provide the control option for everything for every text, button, image, and tag (like margin, padding, size, color, line height, grid gap, and other important CSS styling properties for full accessibility for customization), and the section must be mobile- and tablet-responsive and provide full control also for the mobile- and tablet versions. Other than the button option, make the whole card a clickable item. Apply some beautiful and modern animation on the cards. Provide the display on/off option for the sale tag (that will be on the card image), the button, the rating stars, and the small tag beneath the description. and make the cards or section compatible with the Shopify system. Just like in the conventional featured product section, the whole already-made collection is displayed in cards; rather than adding the data manually in the cards, the data from the pre-made collection automatically fills in. Regarding the button on the card - it can be a modern minimalist button designed with a pretty thin and sleek arrow icon inside a small circle, placed in the bottom right corner of the card, or placed somewhere (like the top right corner) on the card's image (I have also provided a reference image to see how this button will be designed and placed). Lastly, after the grid part, there will be a button to view all. 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-collection-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.section_background_color }};
  }

  .ai-featured-collection__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-featured-collection__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_margin_bottom }}px;
  }

  .ai-featured-collection__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: {{ block.settings.heading_line_height }};
    font-weight: {{ block.settings.heading_font_weight }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
  }

  .ai-featured-collection__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap_desktop }}px;
    margin-bottom: {{ block.settings.grid_margin_bottom }}px;
  }

  .ai-featured-collection__card-{{ ai_gen_id }} {
    position: relative;
    display: flex;
    flex-direction: column;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94), box-shadow 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
    text-decoration: none;
    color: inherit;
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover {
    transform: translateY({{ block.settings.card_hover_lift }}px);
    box-shadow: {{ block.settings.card_hover_shadow_horizontal }}px {{ block.settings.card_hover_shadow_vertical }}px {{ block.settings.card_hover_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_hover_shadow_opacity }});
  }

  .ai-featured-collection__card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: {{ block.settings.image_background_color }};
  }

  .ai-featured-collection__card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover .ai-featured-collection__card-image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_hover_scale }});
  }

  .ai-featured-collection__sale-badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.sale_badge_top }}px;
    left: {{ block.settings.sale_badge_left }}px;
    background-color: {{ block.settings.sale_badge_bg_color }};
    color: {{ block.settings.sale_badge_text_color }};
    padding: {{ block.settings.sale_badge_padding_vertical }}px {{ block.settings.sale_badge_padding_horizontal }}px;
    border-radius: {{ block.settings.sale_badge_border_radius }}px;
    font-size: {{ block.settings.sale_badge_font_size }}px;
    font-weight: {{ block.settings.sale_badge_font_weight }};
    letter-spacing: {{ block.settings.sale_badge_letter_spacing }}px;
    z-index: 2;
  }

  .ai-featured-collection__arrow-button-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.arrow_button_top }}px;
    right: {{ block.settings.arrow_button_right }}px;
    width: {{ block.settings.arrow_button_size }}px;
    height: {{ block.settings.arrow_button_size }}px;
    background-color: {{ block.settings.arrow_button_bg_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: background-color 0.3s ease, transform 0.3s ease;
    border: {{ block.settings.arrow_button_border_width }}px solid {{ block.settings.arrow_button_border_color }};
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover .ai-featured-collection__arrow-button-{{ ai_gen_id }} {
    background-color: {{ block.settings.arrow_button_hover_bg_color }};
    transform: scale(1.1);
  }

  .ai-featured-collection__arrow-icon-{{ ai_gen_id }} {
    width: {{ block.settings.arrow_icon_size }}px;
    height: {{ block.settings.arrow_icon_size }}px;
    stroke: {{ block.settings.arrow_icon_color }};
    transition: stroke 0.3s ease;
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover .ai-featured-collection__arrow-icon-{{ ai_gen_id }} {
    stroke: {{ block.settings.arrow_icon_hover_color }};
  }

  .ai-featured-collection__card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_content_padding_top }}px {{ block.settings.card_content_padding_horizontal }}px {{ block.settings.card_content_padding_bottom }}px;
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.card_content_gap }}px;
    flex-grow: 1;
  }

  .ai-featured-collection__card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0;
    line-height: {{ block.settings.title_line_height }};
    font-weight: {{ block.settings.title_font_weight }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
  }

  .ai-featured-collection__card-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_font_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: {{ block.settings.subtitle_line_height }};
    font-weight: {{ block.settings.subtitle_font_weight }};
    letter-spacing: {{ block.settings.subtitle_letter_spacing }}px;
    opacity: {{ block.settings.subtitle_opacity }};
  }

  .ai-featured-collection__price-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.price_gap }}px;
  }

  .ai-featured-collection__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: {{ block.settings.price_font_weight }};
    line-height: 1;
  }

  .ai-featured-collection__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    opacity: {{ block.settings.compare_price_opacity }};
    font-weight: {{ block.settings.compare_price_font_weight }};
    line-height: 1;
  }

  .ai-featured-collection__rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.rating_gap }}px;
  }

  .ai-featured-collection__stars-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.stars_gap }}px;
  }

  .ai-featured-collection__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-featured-collection__star-empty-{{ ai_gen_id }} {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-featured-collection__rating-count-{{ ai_gen_id }} {
    font-size: {{ block.settings.rating_count_font_size }}px;
    color: {{ block.settings.rating_count_color }};
    opacity: {{ block.settings.rating_count_opacity }};
  }

  .ai-featured-collection__view-all-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.view_all_alignment }};
    margin-top: {{ block.settings.view_all_margin_top }}px;
  }

  .ai-featured-collection__view-all-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.view_all_padding_vertical }}px {{ block.settings.view_all_padding_horizontal }}px;
    background-color: {{ block.settings.view_all_bg_color }};
    color: {{ block.settings.view_all_text_color }};
    border-radius: {{ block.settings.view_all_border_radius }}px;
    font-size: {{ block.settings.view_all_font_size }}px;
    font-weight: {{ block.settings.view_all_font_weight }};
    text-decoration: none;
    transition: background-color 0.3s ease, transform 0.3s ease;
    border: {{ block.settings.view_all_border_width }}px solid {{ block.settings.view_all_border_color }};
    letter-spacing: {{ block.settings.view_all_letter_spacing }}px;
  }

  .ai-featured-collection__view-all-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.view_all_hover_bg_color }};
    color: {{ block.settings.view_all_hover_text_color }};
    transform: translateY(-2px);
  }

  @media screen and (max-width: 989px) {
    .ai-featured-collection__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap_tablet }}px;
    }

    .ai-featured-collection__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_tablet }}px;
    }

    .ai-featured-collection-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_tablet }}px {{ block.settings.section_padding_horizontal_tablet }}px {{ block.settings.section_padding_bottom_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-featured-collection__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-featured-collection__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
    }

    .ai-featured-collection-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-featured-collection__card-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-featured-collection__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_font_size_mobile }}px;
    }
  }
{% endstyle %}

<featured-collection-{{ ai_gen_id }} class="ai-featured-collection-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-collection__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-featured-collection__header-{{ ai_gen_id }}">
        <h2 class="ai-featured-collection__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-featured-collection__grid-{{ ai_gen_id }}">
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <a href="{{ product.url }}" class="ai-featured-collection__card-{{ ai_gen_id }}">
            <div class="ai-featured-collection__card-image-wrapper-{{ ai_gen_id }}">
              {% if product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  class="ai-featured-collection__card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="800"
                  height="{{ 800 | divided_by: product.featured_image.aspect_ratio | round }}"
                >
              {% else %}
                <div class="ai-featured-collection__card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}

              {% if block.settings.show_sale_badge and product.compare_at_price > product.price %}
                <div class="ai-featured-collection__sale-badge-{{ ai_gen_id }}">
                  {{ block.settings.sale_badge_text }}
                </div>
              {% endif %}

              {% if block.settings.show_arrow_button %}
                <div class="ai-featured-collection__arrow-button-{{ ai_gen_id }}">
                  <svg class="ai-featured-collection__arrow-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              {% endif %}
            </div>

            <div class="ai-featured-collection__card-content-{{ ai_gen_id }}">
              <h3 class="ai-featured-collection__card-title-{{ ai_gen_id }}">{{ product.title }}</h3>

              {% if block.settings.show_subtitle and product.metafields.custom.subtitle != blank %}
                <p class="ai-featured-collection__card-subtitle-{{ ai_gen_id }}">{{ product.metafields.custom.subtitle }}</p>
              {% elsif block.settings.show_subtitle and block.settings.default_subtitle != blank %}
                <p class="ai-featured-collection__card-subtitle-{{ ai_gen_id }}">{{ block.settings.default_subtitle }}</p>
              {% endif %}

              <div class="ai-featured-collection__price-wrapper-{{ ai_gen_id }}">
                <span class="ai-featured-collection__price-{{ ai_gen_id }}">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                  <span class="ai-featured-collection__compare-price-{{ ai_gen_id }}">{{ product.compare_at_price | money }}</span>
                {% endif %}
              </div>

              {% if block.settings.show_rating %}
                <div class="ai-featured-collection__rating-{{ ai_gen_id }}">
                  <div class="ai-featured-collection__stars-{{ ai_gen_id }}">
                    {% assign rating = block.settings.default_rating %}
                    {% if product.metafields.reviews.rating.value %}
                      {% assign rating = product.metafields.reviews.rating.value %}
                    {% endif %}
                    {% for i in (1..5) %}
                      {% if i <= rating %}
                        <svg class="ai-featured-collection__star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                        </svg>
                      {% else %}
                        <svg class="ai-featured-collection__star-{{ ai_gen_id }} ai-featured-collection__star-empty-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                          <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                        </svg>
                      {% endif %}
                    {% endfor %}
                  </div>
                  {% if block.settings.show_rating_count %}
                    <span class="ai-featured-collection__rating-count-{{ ai_gen_id }}">
                      {% if product.metafields.reviews.rating_count %}
                        ({{ product.metafields.reviews.rating_count }})
                      {% else %}
                        ({{ block.settings.default_rating_count }})
                      {% endif %}
                    </span>
                  {% endif %}
                </div>
              {% endif %}
            </div>
          </a>
        {% endfor %}
      </div>

      {% if block.settings.show_view_all_button and block.settings.collection != blank %}
        <div class="ai-featured-collection__view-all-wrapper-{{ ai_gen_id }}">
          <a href="{{ block.settings.collection.url }}" class="ai-featured-collection__view-all-button-{{ ai_gen_id }}">
            {{ block.settings.view_all_button_text }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-featured-collection__empty-state-{{ ai_gen_id }}" style="text-align: center; padding: 60px 20px; color: #999;">
        <p style="font-size: 18px; margin: 0;">Select a collection to display products</p>
      </div>
    {% endif %}
  </div>
</featured-collection-{{ ai_gen_id }}>

<script>
(function() {
  class FeaturedCollection{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.cards = this.querySelectorAll('.ai-featured-collection__card-{{ ai_gen_id }}');
      this.setupIntersectionObserver();
    }

    setupIntersectionObserver() {
      const options = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry, index) => {
          if (entry.isIntersecting) {
            setTimeout(() => {
              entry.target.style.opacity = '1';
              entry.target.style.transform = 'translateY(0)';
            }, index * 100);
            observer.unobserve(entry.target);
          }
        });
      }, options);

      this.cards.forEach((card) => {
        card.style.opacity = '0';
        card.style.transform = 'translateY(30px)';
        card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
        observer.observe(card);
      });
    }
  }

  customElements.define('featured-collection-{{ ai_gen_id }}', FeaturedCollection{{ ai_gen_id }});
})();
</script>

