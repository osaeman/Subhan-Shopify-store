{% doc %}
  @prompt
    Create a fully mobile-responsive fade transition slideshow with customizable settings including: text position options (left, center, right alignment), adjustable text sizes for headings and descriptions with line height controls for both, separate color pickers for heading color and description color, customizable button text with button link/URL field for navigation, button size controls, and the ability to add multiple slides with images. The slideshow must be mobile-responsive with auto-adjusting image heights and overlay text sizes at different breakpoints (mobile, tablet, desktop). Include theme editor settings for easy customization of all text positioning, sizing, line heights, colors, button styling, and button link destinations.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-slideshow-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    overflow: hidden;
    display: block;
  }

  .ai-slideshow-container-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.desktop_height }}px;
  }

  .ai-slideshow-slide-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    transition: opacity {{ block.settings.transition_duration }}s ease-in-out;
    pointer-events: none;
  }

  .ai-slideshow-slide-{{ ai_gen_id }}.active {
    opacity: 1;
    pointer-events: auto;
  }

  .ai-slideshow-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .ai-slideshow-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-slideshow-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 500px;
    max-height: 500px;
  }

  .ai-slideshow-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-slideshow-overlay-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: {{ block.settings.overlay_color }};
    opacity: {{ block.settings.overlay_opacity }};
  }

  .ai-slideshow-content-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    padding: 0 40px;
    z-index: 2;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-slideshow-content-{{ ai_gen_id }}--left {
    left: 0;
    text-align: left;
  }

  .ai-slideshow-content-{{ ai_gen_id }}--center {
    left: 0;
    text-align: center;
  }

  .ai-slideshow-content-{{ ai_gen_id }}--right {
    left: 0;
    text-align: right;
  }

  .ai-slideshow-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 16px;
    font-weight: 700;
  }

  .ai-slideshow-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: {{ block.settings.description_line_height }};
    color: {{ block.settings.description_color }};
    margin: 0 0 24px;
  }

  .ai-slideshow-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_size }}px {{ block.settings.button_size | times: 2 }}px;
    background-color: {{ block.settings.button_bg_color }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: 8px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .ai-slideshow-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_bg_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  .ai-slideshow-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_bg_color }};
    color: {{ block.settings.nav_icon_color }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
  }

  .ai-slideshow-nav-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.nav_hover_bg_color }};
  }

  .ai-slideshow-nav-{{ ai_gen_id }}--prev {
    left: 20px;
  }

  .ai-slideshow-nav-{{ ai_gen_id }}--next {
    right: 20px;
  }

  .ai-slideshow-nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
  }

  .ai-slideshow-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 10px;
    z-index: 3;
  }

  .ai-slideshow-dot-{{ ai_gen_id }} {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background-color: {{ block.settings.dot_color }};
    opacity: 0.5;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-slideshow-dot-{{ ai_gen_id }}.active {
    opacity: 1;
    background-color: {{ block.settings.dot_active_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-slideshow-container-{{ ai_gen_id }} {
      height: {{ block.settings.tablet_height }}px;
    }

    .ai-slideshow-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.8 }}px;
    }

    .ai-slideshow-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-slideshow-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
      padding: {{ block.settings.button_size | times: 0.9 }}px {{ block.settings.button_size | times: 1.8 }}px;
    }

    .ai-slideshow-content-{{ ai_gen_id }} {
      padding: 0 30px;
    }

    .ai-slideshow-nav-{{ ai_gen_id }} {
      width: 40px;
      height: 40px;
    }

    .ai-slideshow-nav-{{ ai_gen_id }} svg {
      width: 20px;
      height: 20px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-slideshow-container-{{ ai_gen_id }} {
      height: {{ block.settings.mobile_height }}px;
    }

    .ai-slideshow-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
    }

    .ai-slideshow-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.8 }}px;
    }

    .ai-slideshow-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.8 }}px;
      padding: {{ block.settings.button_size | times: 0.8 }}px {{ block.settings.button_size | times: 1.6 }}px;
    }

    .ai-slideshow-content-{{ ai_gen_id }} {
      padding: 0 20px;
    }

    .ai-slideshow-nav-{{ ai_gen_id }}--prev {
      left: 10px;
    }

    .ai-slideshow-nav-{{ ai_gen_id }}--next {
      right: 10px;
    }

    .ai-slideshow-nav-{{ ai_gen_id }} {
      width: 36px;
      height: 36px;
    }

    .ai-slideshow-nav-{{ ai_gen_id }} svg {
      width: 18px;
      height: 18px;
    }

    .ai-slideshow-dots-{{ ai_gen_id }} {
      bottom: 15px;
    }

    .ai-slideshow-dot-{{ ai_gen_id }} {
      width: 10px;
      height: 10px;
    }
  }
{% endstyle %}

<fade-slideshow-{{ ai_gen_id }} class="ai-slideshow-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-slideshow-container-{{ ai_gen_id }}">
    {% for i in (1..5) %}
      {% liquid
        assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
        assign slide_image_key = 'slide_' | append: i | append: '_image'
        assign slide_heading_key = 'slide_' | append: i | append: '_heading'
        assign slide_description_key = 'slide_' | append: i | append: '_description'
        assign slide_button_text_key = 'slide_' | append: i | append: '_button_text'
        assign slide_button_link_key = 'slide_' | append: i | append: '_button_link'

        assign slide_enabled = block.settings[slide_enabled_key]
        assign slide_image = block.settings[slide_image_key]
        assign slide_heading = block.settings[slide_heading_key]
        assign slide_description = block.settings[slide_description_key]
        assign slide_button_text = block.settings[slide_button_text_key]
        assign slide_button_link = block.settings[slide_button_link_key]
      %}

      {% if slide_enabled %}
        <div class="ai-slideshow-slide-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide-index="{{ forloop.index0 }}">
          <div class="ai-slideshow-image-wrapper-{{ ai_gen_id }}">
            {% if slide_image %}
              <img
                src="{{ slide_image | image_url: width: 2000 }}"
                alt="{{ slide_image.alt | escape }}"
                loading="lazy"
                width="{{ slide_image.width }}"
                height="{{ slide_image.height }}"
                class="ai-slideshow-image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-slideshow-placeholder-{{ ai_gen_id }}">
                {{ 'hero-apparel-1' | placeholder_svg_tag }}
                <div class="ai-slideshow-empty-state-{{ ai_gen_id }}">
                  Add an image for slide {{ i }}
                </div>
              </div>
            {% endif %}
            <div class="ai-slideshow-overlay-{{ ai_gen_id }}"></div>
          </div>

          <div class="ai-slideshow-content-{{ ai_gen_id }} ai-slideshow-content-{{ ai_gen_id }}--{{ block.settings.text_alignment }}">
            {% if slide_heading != blank %}
              <h2 class="ai-slideshow-heading-{{ ai_gen_id }}">{{ slide_heading }}</h2>
            {% endif %}

            {% if slide_description != blank %}
              <div class="ai-slideshow-description-{{ ai_gen_id }}">{{ slide_description }}</div>
            {% endif %}

            {% if slide_button_text != blank %}
              <a href="{{ slide_button_link }}" class="ai-slideshow-button-{{ ai_gen_id }}">
                {{ slide_button_text }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    {% endfor %}

    {% if block.settings.show_navigation %}
      <button class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-{{ ai_gen_id }}--prev" aria-label="Previous slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button class="ai-slideshow-nav-{{ ai_gen_id }} ai-slideshow-nav-{{ ai_gen_id }}--next" aria-label="Next slide">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    {% endif %}

    {% if block.settings.show_dots %}
      <div class="ai-slideshow-dots-{{ ai_gen_id }}">
        {% for i in (1..5) %}
          {% liquid
            assign slide_enabled_key = 'slide_' | append: i | append: '_enabled'
            assign slide_enabled = block.settings[slide_enabled_key]
          %}
          {% if slide_enabled %}
            <button class="ai-slideshow-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}" data-slide-index="{{ forloop.index0 }}" aria-label="Go to slide {{ i }}"></button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</fade-slideshow-{{ ai_gen_id }}>

<script>
  (function() {
    class FadeSlideshow{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentSlide = 0;
        this.slides = [];
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.slides = Array.from(this.querySelectorAll('.ai-slideshow-slide-{{ ai_gen_id }}'));
        this.dots = Array.from(this.querySelectorAll('.ai-slideshow-dot-{{ ai_gen_id }}'));
        this.prevButton = this.querySelector('.ai-slideshow-nav-{{ ai_gen_id }}--prev');
        this.nextButton = this.querySelector('.ai-slideshow-nav-{{ ai_gen_id }}--next');

        if (this.slides.length === 0) return;

        this.setupEventListeners();
        
        {% if block.settings.autoplay %}
          this.startAutoplay();
        {% endif %}
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.previousSlide());
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.nextSlide());
        }

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', () => this.goToSlide(index));
        });

        this.addEventListener('mouseenter', () => this.stopAutoplay());
        this.addEventListener('mouseleave', () => {
          {% if block.settings.autoplay %}
            this.startAutoplay();
          {% endif %}
        });
      }

      nextSlide() {
        this.currentSlide = (this.currentSlide + 1) % this.slides.length;
        this.updateSlides();
      }

      previousSlide() {
        this.currentSlide = (this.currentSlide - 1 + this.slides.length) % this.slides.length;
        this.updateSlides();
      }

      goToSlide(index) {
        this.currentSlide = index;
        this.updateSlides();
      }

      updateSlides() {
        this.slides.forEach((slide, index) => {
          if (index === this.currentSlide) {
            slide.classList.add('active');
          } else {
            slide.classList.remove('active');
          }
        });

        this.dots.forEach((dot, index) => {
          if (index === this.currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          this.nextSlide();
        }, {{ block.settings.autoplay_duration | times: 1000 }});
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('fade-slideshow-{{ ai_gen_id }}', FadeSlideshow{{ ai_gen_id }});
  })();
</script>

