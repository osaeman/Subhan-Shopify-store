{% endstyle %}

<featured-section-{{ ai_gen_id }} class="ai-featured-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-section__container-{{ ai_gen_id }}">
    {% if block.settings.main_heading != blank %}
      <h2 class="ai-featured-section__heading-{{ ai_gen_id }}">{{ block.settings.main_heading }}</h2>
    {% endif %}

    <div class="ai-featured-section__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'card_' | append: i | append: '_image'
          assign title_key = 'card_' | append: i | append: '_title'
          assign subtitle_key = 'card_' | append: i | append: '_subtitle'
          assign description_key = 'card_' | append: i | append: '_description'

          assign card_image = block.settings[image_key]
          assign card_title = block.settings[title_key]
          assign card_subtitle = block.settings[subtitle_key]
          assign card_description = block.settings[description_key]
        %}

        <div class="ai-featured-section__card-{{ ai_gen_id }}">
          <div class="ai-featured-section__image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                class="ai-featured-section__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-featured-section__image-placeholder-{{ ai_gen_id }}">
                {{ 'image' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="ai-featured-section__content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-featured-section__card-title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}

            {% if card_subtitle != blank %}
              <p class="ai-featured-section__card-subtitle-{{ ai_gen_id }}">{{ card_subtitle }}</p>
            {% endif %}

            {% if card_description != blank %}
              <div class="ai-featured-section__card-description-{{ ai_gen_id }}">{{ card_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</featured-section-{{ ai_gen_id }}>

<script>
  (function() {
    class FeaturedSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-featured-section__card-{{ ai_gen_id }}');
        this.setupObserver();
      }

      setupObserver() {
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }, index * 100);
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        this.cards.forEach((card) => {
          card.style.opacity = '0';
          card.style.transform = 'translateY(20px)';
          card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          observer.observe(card);
        });
      }
    }

    customElements.define('featured-section-{{ ai_gen_id }}', FeaturedSection{{ ai_gen_id }});
  })();
</script>

