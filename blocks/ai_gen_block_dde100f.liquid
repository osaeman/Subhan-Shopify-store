{% doc %}
  @prompt
    Design a featured product like section. Design clean, modern, sleek, minimalist, and unique card designs. First there will be main heading. Then it should display 4 cards (4 grid) in a row, The card first has image then heading/tittle of the card, then a small text and description text. Cards and images should have a nice and subtle animation. Also, provide the control option for everything for every text, heading, image, layout of section (like all margins, all paddings, size, colour, font-weight, line height, grid gap, image properties like object-fit, object position (image height), image box shadow ( and other important CSS styling properties for full accessibility for customization), and the section must be mobile- and tablet-responsive and provide full setting or all CSS styling properties for the mobile- and tablet versions also that have been mentioned for the desktop version.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    padding-left: {{ block.settings.section_padding_left }}px;
    padding-right: {{ block.settings.section_padding_right }}px;
    background-color: {{ block.settings.section_bg_color }};
  }

  .ai-featured-section__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-featured-section__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    margin-top: {{ block.settings.heading_margin_top }}px;
    margin-bottom: {{ block.settings.heading_margin_bottom }}px;
    margin-left: 0;
    margin-right: 0;
  }

  .ai-featured-section__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.grid_columns }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    margin-top: {{ block.settings.grid_margin_top }}px;
  }

  .ai-featured-section__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_bg_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
  }

  .ai-featured-section__card-{{ ai_gen_id }}:hover {
    transform: translateY({{ block.settings.card_hover_translate_y }}px);
    box-shadow: {{ block.settings.card_hover_shadow_x }}px {{ block.settings.card_hover_shadow_y }}px {{ block.settings.card_hover_shadow_blur }}px {{ block.settings.card_hover_shadow_color }};
  }

  .ai-featured-section__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    height: {{ block.settings.image_height }}px;
    overflow: hidden;
  }

  .ai-featured-section__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: {{ block.settings.image_object_fit }};
    object-position: {{ block.settings.image_object_position }};
    transition: transform 0.5s ease;
  }

  .ai-featured-section__card-{{ ai_gen_id }}:hover .ai-featured-section__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_hover_scale }});
  }

  .ai-featured-section__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-featured-section__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-featured-section__content-{{ ai_gen_id }} {
    padding-top: {{ block.settings.card_content_padding_top }}px;
    padding-bottom: {{ block.settings.card_content_padding_bottom }}px;
    padding-left: {{ block.settings.card_content_padding_left }}px;
    padding-right: {{ block.settings.card_content_padding_right }}px;
  }

  .ai-featured-section__card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_font_size }}px;
    font-weight: {{ block.settings.card_title_font_weight }};
    line-height: {{ block.settings.card_title_line_height }};
    color: {{ block.settings.card_title_color }};
    margin-top: 0;
    margin-bottom: {{ block.settings.card_title_margin_bottom }}px;
  }

  .ai-featured-section__card-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_subtitle_font_size }}px;
    font-weight: {{ block.settings.card_subtitle_font_weight }};
    line-height: {{ block.settings.card_subtitle_line_height }};
    color: {{ block.settings.card_subtitle_color }};
    margin-top: 0;
    margin-bottom: {{ block.settings.card_subtitle_margin_bottom }}px;
  }

  .ai-featured-section__card-description-{{ ai_gen_id }} {
