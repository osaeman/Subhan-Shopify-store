{% doc %}
  @prompt
    I want you to design a section similar to the featured product section of Shopify, but obviously with a modern, sleek, and e-commerce-oriented beautiful design. The section will have a heading first, and then it will have a grid of 4 (for the laptop version), and every grid hosts a product card. The card has an image of the product, then the title of the product, then a small subtle tag (for example, like "Unstitched | New Arrival"), and then the price of the product (also the discounted price, other, or cut price, or compare price option, whatever you call it—designed in a very minimalist and subtle manner). Then the product star rating or rating in a unique way is designed, and a beautiful, homogenous button is created. The overall design of the section must be a sleek, modern, mimialist and elegant e-commerce UI. Also, provide the control option for everything for every text, button, image, and tag (like margin, padding, size, color, line height, grid gap, and other important CSS styling properties for full accessibility for customization), and the section must be mobile- and tablet-responsive and provide full control also for the mobile- and tablet versions. Other than the button option, make the whole card a clickable item. Apply some beautiful and modern animation on the cards. Provide the display on/off option for the sale tag (that will be on the card image), the button, the rating stars, and the small tag beneath the description. and make the cards or section compatible with the Shopify system. Just like in the conventional featured product section, the whole already made collection is displayed in cards; rather than adding the data manually in the cards, the data from the pre-made collection automatically fills in. Regarding the button on the card - it can be a modern minimalist button at the end of the card spanning across the width of the card, or a pretty thin and sleek arrow icon inside a circle, placed in the bottom right corner of the card or placed somewhere on the image. Lastly, after the grid part, there will be a button to view all.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-collection-{{ ai_gen_id }} {
    display: block;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.section_background_color }};
    width: 100%;
  }

  .ai-featured-collection__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-featured-collection__header-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
    margin-bottom: {{ block.settings.heading_margin_bottom }}px;
  }

  .ai-featured-collection__heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
    line-height: {{ block.settings.heading_line_height }};
    font-weight: {{ block.settings.heading_font_weight }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
  }

  .ai-featured-collection__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.grid_columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap_desktop }}px;
    margin-bottom: {{ block.settings.grid_margin_bottom }}px;
  }

  .ai-featured-collection__card-{{ ai_gen_id }} {
    position: relative;
    background-color: {{ block.settings.card_background_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: {{ block.settings.card_shadow_horizontal }}px {{ block.settings.card_shadow_vertical }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover {
    transform: translateY({{ block.settings.card_hover_translate_y }}px);
    box-shadow: {{ block.settings.card_hover_shadow_horizontal }}px {{ block.settings.card_hover_shadow_vertical }}px {{ block.settings.card_hover_shadow_blur }}px {{ block.settings.card_hover_shadow_color }};
  }

  .ai-featured-collection__card-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-featured-collection__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background-color: {{ block.settings.image_background_color }};
  }

  .ai-featured-collection__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .ai-featured-collection__card-{{ ai_gen_id }}:hover .ai-featured-collection__image-{{ ai_gen_id }} {
    transform: scale({{ block.settings.image_hover_scale }});
  }

  .ai-featured-collection__sale-badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.sale_badge_top }}px;
    left: {{ block.settings.sale_badge_left }}px;
    background-color: {{ block.settings.sale_badge_background }};
    color: {{ block.settings.sale_badge_text_color }};
    padding: {{ block.settings.sale_badge_padding_vertical }}px {{ block.settings.sale_badge_padding_horizontal }}px;
    border-radius: {{ block.settings.sale_badge_border_radius }}px;
    font-size: {{ block.settings.sale_badge_font_size }}px;
    font-weight: {{ block.settings.sale_badge_font_weight }};
    z-index: 2;
    letter-spacing: {{ block.settings.sale_badge_letter_spacing }}px;
  }

  .ai-featured-collection__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_content_padding }}px;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .ai-featured-collection__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    line-height: {{ block.settings.title_line_height }};
    font-weight: {{ block.settings.title_font_weight }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
  }

  .ai-featured-collection__tag-{{ ai_gen_id }} {
    font-size: {{ block.settings.tag_font_size }}px;
    color: {{ block.settings.tag_color }};
    margin-bottom: {{ block.settings.tag_margin_bottom }}px;
    font-weight: {{ block.settings.tag_font_weight }};
    letter-spacing: {{ block.settings.tag_letter_spacing }}px;
    opacity: {{ block.settings.tag_opacity }};
  }

  .ai-featured-collection__price-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.price_margin_bottom }}px;
  }

  .ai-featured-collection__price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: {{ block.settings.price_font_weight }};
    letter-spacing: {{ block.settings.price_letter_spacing }}px;
  }

  .ai-featured-collection__compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    margin-left: {{ block.settings.compare_price_margin_left }}px;
    opacity: {{ block.settings.compare_price_opacity }};
    font-weight: {{ block.settings.compare_price_font_weight }};
  }

  .ai-featured-collection__rating-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.rating_gap }}px;
    margin-bottom: {{ block.settings.rating_margin_bottom }}px;
  }

  .ai-featured-collection__stars-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.stars_gap }}px;
  }

  .ai-featured-collection__star-{{ ai_gen_id }} {
    width: {{ block.settings.star_size }}px;
    height: {{ block.settings.star_size }}px;
    fill: {{ block.settings.star_color }};
  }

  .ai-featured-collection__star-empty-{{ ai_gen_id }} {
    fill: {{ block.settings.star_empty_color }};
  }

  .ai-featured-collection__rating-count-{{ ai_gen_id }} {
    font-size: {{ block.settings.rating_count_font_size }}px;
    color: {{ block.settings.rating_count_color }};
    opacity: {{ block.settings.rating_count_opacity }};
  }

  .ai-featured-collection__button-wrapper-{{ ai_gen_id }} {
    margin-top: auto;
  }

  .ai-featured-collection__button-full-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
  }

  .ai-featured-collection__button-full-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-featured-collection__button-icon-{{ ai_gen_id }} {
    position: absolute;
    bottom: {{ block.settings.icon_button_bottom }}px;
    right: {{ block.settings.icon_button_right }}px;
    width: {{ block.settings.icon_button_size }}px;
    height: {{ block.settings.icon_button_size }}px;
    background-color: {{ block.settings.icon_button_background }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 3;
    border: {{ block.settings.icon_button_border_width }}px solid {{ block.settings.icon_button_border_color }};
  }

  .ai-featured-collection__button-icon-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.icon_button_hover_background }};
    transform: scale(1.1);
  }

  .ai-featured-collection__button-icon-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-featured-collection__view-all-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.view_all_alignment }};
    margin-top: {{ block.settings.view_all_margin_top }}px;
  }

  .ai-featured-collection__view-all-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.view_all_padding_vertical }}px {{ block.settings.view_all_padding_horizontal }}px;
    background-color: {{ block.settings.view_all_background }};
    color: {{ block.settings.view_all_text_color }};
    border: {{ block.settings.view_all_border_width }}px solid {{ block.settings.view_all_border_color }};
    border-radius: {{ block.settings.view_all_border_radius }}px;
    font-size: {{ block.settings.view_all_font_size }}px;
    font-weight: {{ block.settings.view_all_font_weight }};
    text-decoration: none;
    transition: all 0.3s ease;
    letter-spacing: {{ block.settings.view_all_letter_spacing }}px;
  }

  .ai-featured-collection__view-all-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.view_all_hover_background }};
    color: {{ block.settings.view_all_hover_text_color }};
    border-color: {{ block.settings.view_all_hover_border_color }};
  }

  @media screen and (max-width: 989px) {
    .ai-featured-collection__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.grid_columns_tablet }}, 1fr);
      gap: {{ block.settings.grid_gap_tablet }}px;
    }

    .ai-featured-collection__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_tablet }}px;
    }

    .ai-featured-collection-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_tablet }}px {{ block.settings.section_padding_horizontal_tablet }}px {{ block.settings.section_padding_bottom_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-featured-collection__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.grid_columns_mobile }}, 1fr);
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-featured-collection__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
    }

    .ai-featured-collection-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px;
    }

    .ai-featured-collection__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-featured-collection__price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-featured-collection-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-featured-collection__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <div class="ai-featured-collection__header-{{ ai_gen_id }}">
        <h2 class="ai-featured-collection__heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}

    {% if block.settings.collection != blank %}
      <div class="ai-featured-collection__grid-{{ ai_gen_id }}">
        {% for product in block.settings.collection.products limit: block.settings.products_to_show %}
          <div class="ai-featured-collection__card-{{ ai_gen_id }}">
            <a href="{{ product.url }}" class="ai-featured-collection__card-link-{{ ai_gen_id }}">
              <div class="ai-featured-collection__image-wrapper-{{ ai_gen_id }}">
                {% if product.featured_image %}
                  <img
                    src="{{ product.featured_image | image_url: width: 800 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    class="ai-featured-collection__image-{{ ai_gen_id }}"
                    loading="lazy"
                    width="800"
                    height="{{ 800 | divided_by: product.featured_image.aspect_ratio | round }}"
                  >
                {% else %}
                  <div class="ai-featured-collection__image-placeholder-{{ ai_gen_id }}">
                    {{ 'product-1' | placeholder_svg_tag }}
                  </div>
                {% endif %}

                {% if block.settings.show_sale_badge and product.compare_at_price > product.price %}
                  <div class="ai-featured-collection__sale-badge-{{ ai_gen_id }}">
                    {{ block.settings.sale_badge_text }}
                  </div>
                {% endif %}

                {% if block.settings.button_style == 'icon' %}
                  <div class="ai-featured-collection__button-icon-{{ ai_gen_id }}">
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                {% endif %}
              </div>

              <div class="ai-featured-collection__content-{{ ai_gen_id }}">
                <h3 class="ai-featured-collection__title-{{ ai_gen_id }}">{{ product.title }}</h3>

                {% if block.settings.show_product_tag and block.settings.product_tag_text != blank %}
                  <div class="ai-featured-collection__tag-{{ ai_gen_id }}">
                    {{ block.settings.product_tag_text }}
                  </div>
                {% endif %}

                <div class="ai-featured-collection__price-wrapper-{{ ai_gen_id }}">
                  <span class="ai-featured-collection__price-{{ ai_gen_id }}">
                    {{ product.price | money }}
                  </span>
                  {% if product.compare_at_price > product.price %}
                    <span class="ai-featured-collection__compare-price-{{ ai_gen_id }}">
                      {{ product.compare_at_price | money }}
                    </span>
                  {% endif %}
                </div>

                {% if block.settings.show_rating %}
                  <div class="ai-featured-collection__rating-{{ ai_gen_id }}">
                    <div class="ai-featured-collection__stars-{{ ai_gen_id }}">
                      {% for i in (1..5) %}
                        {% if i <= block.settings.rating_value %}
                          <svg class="ai-featured-collection__star-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                          </svg>
                        {% else %}
                          <svg class="ai-featured-collection__star-{{ ai_gen_id }} ai-featured-collection__star-empty-{{ ai_gen_id }}" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                            <path d="M12 2L15.09 8.26L22 9.27L17 14.14L18.18 21.02L12 17.77L5.82 21.02L7 14.14L2 9.27L8.91 8.26L12 2Z"/>
                          </svg>
                        {% endif %}
                      {% endfor %}
                    </div>
                    {% if block.settings.show_rating_count %}
                      <span class="ai-featured-collection__rating-count-{{ ai_gen_id }}">
                        ({{ block.settings.rating_count }})
                      </span>
                    {% endif %}
                  </div>
                {% endif %}

                {% if block.settings.show_button and block.settings.button_style == 'full' %}
                  <div class="ai-featured-collection__button-wrapper-{{ ai_gen_id }}">
                    <button class="ai-featured-collection__button-full-{{ ai_gen_id }}">
                      {{ block.settings.button_text }}
                    </button>
                  </div>
                {% endif %}
              </div>
            </a>
          </div>
        {% endfor %}
      </div>

      {% if block.settings.show_view_all and block.settings.collection != blank %}
        <div class="ai-featured-collection__view-all-wrapper-{{ ai_gen_id }}">
          <a href="{{ block.settings.collection.url }}" class="ai-featured-collection__view-all-{{ ai_gen_id }}">
            {{ block.settings.view_all_text }}
          </a>
        </div>
      {% endif %}
    {% else %}
      <div class="ai-featured-collection__empty-state-{{ ai_gen_id }}" style="text-align: center; padding: 60px 20px; color: #999;">
        <p style="font-size: 18px; margin: 0;">Select a collection to display products</p>
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Featured collection",
  "settings": [
    {
      "type": "header",
      "content": "Collection"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 12,
      "step": 1,
      "label": "Products to show",
      "default": 4
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "range",
      "id": "container_max_width",
      "min": 800,
      "max": 1600,
      "step": 50,
      "unit": "px",
      "label": "Container max width",
      "default": 1200
    },
    {
      "type": "color",
      "id": "section_background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "section_padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "section_padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 20
    },
    {
      "type": "header",
      "content": "Section layout tablet"
    },
    {
      "type": "range",
      "id": "section_padding_top_tablet",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_bottom_tablet",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 50
    },
    {
      "type": "range",
      "id": "section_padding_horizontal_tablet",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 20
    },
    {
      "type": "header",
      "content": "Section layout mobile"
    },
    {
      "type": "range",
      "id": "section_padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "section_padding_horizontal_mobile",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Padding horizontal",
      "default": 15
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Collection"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Font size desktop",
      "default": 42
    },
    {
      "type": "range",
      "id": "heading_font_size_tablet",
      "min": 18,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Font size tablet",
      "default": 36
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "min": 16,
      "max": 50,
      "step": 2,
      "unit": "px",
      "label": "Font size mobile",
      "default": 28
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#2e2a39"
    },
    {
      "type": "range",
      "id": "heading_line_height",
      "min": 1,
      "max": 2,
      "step": 0.1,
      "label": "Line height",
      "default": 1.2
    },
    {
      "type": "range",
      "id": "heading_font_weight",
      "min": 300,
      "max": 900,
      "step": 100,
      "label": "Font weight",
      "default": 700
    },
    {
      "type": "range",
      "id": "heading_letter_spacing",
      "min": -2,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "label": "Letter spacing",
      "default": 0
    },
    {
      "type": "range",
      "id": "heading_margin_bottom",
      "min": 10,
      "max": 80,
      "step": 5,
      "unit": "px",
      "label": "Margin bottom",
      "default": 40
    },
    {
      "type": "header",
      "content": "Grid layout"
    },
    {
      "type": "range",
      "id": "grid_columns_desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Columns desktop",
      "default": 4
    },
    {
      "type": "range",
      "id": "grid_columns_tablet",
