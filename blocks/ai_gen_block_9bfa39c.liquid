{% doc %}
  @prompt
    Create a sleek modern announcement bar section with continuous horizontal scrolling text animation. The text should smoothly slide from right to left across the screen and seamlessly loop back, creating an infinite marquee effect. The design should be minimal and contemporary with smooth CSS animations that make the text enter from one side and continuously re-enter from the other side without any gaps or pauses., Move it above in the header section. and make it like that so I can add three different texts, rather than adding only one.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-marquee-bar-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
    position: relative;
    padding: {{ block.settings.vertical_padding }}px 0;
  }

  .ai-marquee-bar__track-{{ ai_gen_id }} {
    display: flex;
    width: max-content;
    animation: ai-marquee-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
  }

  .ai-marquee-bar__content-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    white-space: nowrap;
  }

  .ai-marquee-bar__item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    padding-right: {{ block.settings.item_spacing }}px;
  }

  .ai-marquee-bar__text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-weight: {{ block.settings.font_weight }};
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {% if block.settings.uppercase %}uppercase{% else %}none{% endif %};
  }

  .ai-marquee-bar__separator-{{ ai_gen_id }} {
    display: inline-block;
    width: {{ block.settings.separator_size }}px;
    height: {{ block.settings.separator_size }}px;
    background-color: {{ block.settings.separator_color }};
    border-radius: 50%;
    margin: 0 {{ block.settings.item_spacing | divided_by: 2 }}px;
  }

  @keyframes ai-marquee-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .ai-marquee-bar__track-{{ ai_gen_id }} {
      animation: none;
    }
  }
{% endstyle %}

<announcement-marquee-{{ ai_gen_id }} class="ai-marquee-bar-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-marquee-bar__track-{{ ai_gen_id }}">
    {% for i in (1..2) %}
      <div class="ai-marquee-bar__content-{{ ai_gen_id }}">
        {% if block.settings.text_1 != blank %}
          <div class="ai-marquee-bar__item-{{ ai_gen_id }}">
            <span class="ai-marquee-bar__text-{{ ai_gen_id }}">{{ block.settings.text_1 }}</span>
            {% if block.settings.show_separator %}
              <span class="ai-marquee-bar__separator-{{ ai_gen_id }}"></span>
            {% endif %}
          </div>
        {% endif %}
        
        {% if block.settings.text_2 != blank %}
          <div class="ai-marquee-bar__item-{{ ai_gen_id }}">
            <span class="ai-marquee-bar__text-{{ ai_gen_id }}">{{ block.settings.text_2 }}</span>
            {% if block.settings.show_separator %}
              <span class="ai-marquee-bar__separator-{{ ai_gen_id }}"></span>
            {% endif %}
          </div>
        {% endif %}
        
        {% if block.settings.text_3 != blank %}
          <div class="ai-marquee-bar__item-{{ ai_gen_id }}">
            <span class="ai-marquee-bar__text-{{ ai_gen_id }}">{{ block.settings.text_3 }}</span>
            {% if block.settings.show_separator %}
              <span class="ai-marquee-bar__separator-{{ ai_gen_id }}"></span>
            {% endif %}
          </div>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</announcement-marquee-{{ ai_gen_id }}>

<script>
  (function() {
    class AnnouncementMarquee{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-marquee-bar__track-{{ ai_gen_id }}');
        this.content = this.querySelector('.ai-marquee-bar__content-{{ ai_gen_id }}');
        
        if (this.track && this.content) {
          this.duplicateContent();
        }
      }

      duplicateContent() {
        const contentWidth = this.content.offsetWidth;
        const repetitionsNeeded = Math.ceil((window.innerWidth * 2) / contentWidth) + 2;
        
        const currentChildren = this.track.children.length;
        const childrenToAdd = repetitionsNeeded - currentChildren;
        
        if (childrenToAdd > 0) {
          for (let i = 0; i < childrenToAdd; i++) {
            const clone = this.content.cloneNode(true);
            this.track.appendChild(clone);
          }
        }
      }
    }

    customElements.define('announcement-marquee-{{ ai_gen_id }}', AnnouncementMarquee{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Announcement marquee",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "text_1",
      "label": "Text 1",
      "default": "Free shipping on orders over $50"
    },
    {
      "type": "inline_richtext",
      "id": "text_2",
      "label": "Text 2",
      "default": "Shop now and save 20%"
    },
    {
      "type": "inline_richtext",
      "id": "text_3",
      "label": "Text 3",
      "default": "New arrivals every week"
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show separator",
      "default": true
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#2e2a39"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#fdfbf7"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "select",
      "id": "font_weight",
      "label": "Font weight",
      "options": [
        {
          "value": "400",
          "label": "Normal"
        },
        {
          "value": "500",
          "label": "Medium"
        },
        {
          "value": "600",
          "label": "Semi-bold"
        },
        {
          "value": "700",
          "label": "Bold"
        }
      ],
      "default": "500"
    },
    {
      "type": "checkbox",
      "id": "uppercase",
      "label": "Uppercase text",
      "default": false
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 5,
      "step": 0.5,
      "unit": "px",
      "default": 0.5
    },
    {
      "type": "range",
      "id": "vertical_padding",
      "label": "Vertical padding",
      "min": 8,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "header",
      "content": "Separator"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#fdfbf7"
    },
    {
      "type": "range",
      "id": "separator_size",
      "label": "Separator size",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "px",
      "default": 4
    },
    {
      "type": "range",
      "id": "item_spacing",
      "label": "Item spacing",
      "min": 20,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Announcement marquee"
    }
  ]
}
{% endschema %}
