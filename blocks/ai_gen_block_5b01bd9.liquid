{% doc %}
  @prompt
    Design a very sleek, stylish, and modern design for the About Us section. Design the about us section as you have designed earlier but also, provide the control option for everything for every text, image, heading, statistics, layout of section (like margin, padding, size, colour, font-weight, line height, grid gap, image properties like object-fit, object position( and other important CSS styling properties for full accessibility for customization), and the section must be mobile- and tablet-responsive and provide full control (as for desktop version) for the mobile- and tablet versions also so I can tweak things a bit accordingly., Rest everything is fine. Just a bit of change in the layout is required. Move the "About Our Story" and "Crafting excellence since day one" inside the grid that contains the text or textual content. "about our story" will be in small size and appears first in the stack, then the "Crafting excellence since day one" will appear and will be the heading and then the rest of the content., Rest everything is perfectly fine; just do one more thing—provide margin bottom option also for the "small heading" and also for the "main heading" as there is much white space in between. and also provide box-shadow or drop shadow properties for the image.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-about-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.section_bg_color }};
    padding-top: {{ block.settings.section_padding_top }}px;
    padding-bottom: {{ block.settings.section_padding_bottom }}px;
    padding-left: {{ block.settings.section_padding_left }}px;
    padding-right: {{ block.settings.section_padding_right }}px;
    margin-top: {{ block.settings.section_margin_top }}px;
    margin-bottom: {{ block.settings.section_margin_bottom }}px;
  }

  .ai-about-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-about-content-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {% if block.settings.layout == 'image-left' %}{{ block.settings.image_width }}% 1fr{% elsif block.settings.layout == 'image-right' %}1fr {{ block.settings.image_width }}%{% else %}1fr{% endif %};
    gap: {{ block.settings.grid_gap }}px;
    align-items: {{ block.settings.vertical_alignment }};
  }

  .ai-about-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    {% if block.settings.layout == 'image-right' %}
      order: 2;
    {% endif %}
  }

  .ai-about-image-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    object-fit: {{ block.settings.image_object_fit }};
    object-position: {{ block.settings.image_object_position }};
    border-radius: {{ block.settings.image_border_radius }}px;
    box-shadow: {{ block.settings.image_shadow_horizontal }}px {{ block.settings.image_shadow_vertical }}px {{ block.settings.image_shadow_blur }}px {{ block.settings.image_shadow_spread }}px {{ block.settings.image_shadow_color }};
  }

  .ai-about-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    box-shadow: {{ block.settings.image_shadow_horizontal }}px {{ block.settings.image_shadow_vertical }}px {{ block.settings.image_shadow_blur }}px {{ block.settings.image_shadow_spread }}px {{ block.settings.image_shadow_color }};
  }

  .ai-about-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-about-text-content-{{ ai_gen_id }} {
    {% if block.settings.layout == 'image-right' %}
      order: 1;
    {% endif %}
  }

  .ai-about-heading-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-about-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    font-weight: {{ block.settings.heading_font_weight }};
    line-height: {{ block.settings.heading_line_height }};
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
  }

  .ai-about-subheading-{{ ai_gen_id }} {
    font-size: {{ block.settings.subheading_font_size }}px;
    font-weight: {{ block.settings.subheading_font_weight }};
    line-height: {{ block.settings.subheading_line_height }};
    color: {{ block.settings.subheading_color }};
    margin-top: {{ block.settings.subheading_margin_top }}px;
    margin-bottom: {{ block.settings.subheading_margin_bottom }}px;
    letter-spacing: {{ block.settings.subheading_letter_spacing }}px;
  }

  .ai-about-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    font-weight: {{ block.settings.description_font_weight }};
    line-height: {{ block.settings.description_line_height }};
    color: {{ block.settings.description_color }};
    margin-bottom: {{ block.settings.description_margin_bottom }}px;
    letter-spacing: {{ block.settings.description_letter_spacing }}px;
  }

  .ai-about-stats-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.stats_columns }}, 1fr);
    gap: {{ block.settings.stats_gap }}px;
    margin-top: {{ block.settings.stats_margin_top }}px;
  }

  .ai-about-stat-item-{{ ai_gen_id }} {
    text-align: {{ block.settings.stats_alignment }};
    padding: {{ block.settings.stat_padding }}px;
    background-color: {{ block.settings.stat_bg_color }};
    border-radius: {{ block.settings.stat_border_radius }}px;
  }

  .ai-about-stat-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_number_font_size }}px;
    font-weight: {{ block.settings.stat_number_font_weight }};
    line-height: {{ block.settings.stat_number_line_height }};
    color: {{ block.settings.stat_number_color }};
    margin: 0 0 {{ block.settings.stat_number_margin_bottom }}px 0;
  }

  .ai-about-stat-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_label_font_size }}px;
    font-weight: {{ block.settings.stat_label_font_weight }};
    line-height: {{ block.settings.stat_label_line_height }};
    color: {{ block.settings.stat_label_color }};
    margin: 0;
  }

  @media screen and (max-width: 989px) {
    .ai-about-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.section_padding_top_tablet }}px;
      padding-bottom: {{ block.settings.section_padding_bottom_tablet }}px;
      padding-left: {{ block.settings.section_padding_left_tablet }}px;
      padding-right: {{ block.settings.section_padding_right_tablet }}px;
      margin-top: {{ block.settings.section_margin_top_tablet }}px;
      margin-bottom: {{ block.settings.section_margin_bottom_tablet }}px;
    }

    .ai-about-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_tablet }}px;
      line-height: {{ block.settings.heading_line_height_tablet }};
      margin-bottom: {{ block.settings.heading_margin_bottom_tablet }}px;
    }

    .ai-about-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_font_size_tablet }}px;
      line-height: {{ block.settings.subheading_line_height_tablet }};
      margin-top: {{ block.settings.subheading_margin_top_tablet }}px;
      margin-bottom: {{ block.settings.subheading_margin_bottom_tablet }}px;
    }

    .ai-about-content-grid-{{ ai_gen_id }} {
      grid-template-columns: {% if block.settings.layout_tablet == 'stacked' %}1fr{% elsif block.settings.layout_tablet == 'image-left' %}{{ block.settings.image_width_tablet }}% 1fr{% else %}1fr {{ block.settings.image_width_tablet }}%{% endif %};
      gap: {{ block.settings.grid_gap_tablet }}px;
    }

    .ai-about-image-{{ ai_gen_id }},
    .ai-about-image-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.image_height_tablet }}px;
      border-radius: {{ block.settings.image_border_radius_tablet }}px;
      box-shadow: {{ block.settings.image_shadow_horizontal_tablet }}px {{ block.settings.image_shadow_vertical_tablet }}px {{ block.settings.image_shadow_blur_tablet }}px {{ block.settings.image_shadow_spread_tablet }}px {{ block.settings.image_shadow_color }};
    }

    .ai-about-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size_tablet }}px;
      line-height: {{ block.settings.description_line_height_tablet }};
      margin-bottom: {{ block.settings.description_margin_bottom_tablet }}px;
    }

    .ai-about-stats-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.stats_columns_tablet }}, 1fr);
      gap: {{ block.settings.stats_gap_tablet }}px;
      margin-top: {{ block.settings.stats_margin_top_tablet }}px;
    }

    .ai-about-stat-item-{{ ai_gen_id }} {
      padding: {{ block.settings.stat_padding_tablet }}px;
      border-radius: {{ block.settings.stat_border_radius_tablet }}px;
    }

    .ai-about-stat-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_number_font_size_tablet }}px;
      line-height: {{ block.settings.stat_number_line_height_tablet }};
      margin-bottom: {{ block.settings.stat_number_margin_bottom_tablet }}px;
    }

    .ai-about-stat-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_label_font_size_tablet }}px;
      line-height: {{ block.settings.stat_label_line_height_tablet }};
    }
  }

  @media screen and (max-width: 749px) {
    .ai-about-section-{{ ai_gen_id }} {
      padding-top: {{ block.settings.section_padding_top_mobile }}px;
      padding-bottom: {{ block.settings.section_padding_bottom_mobile }}px;
      padding-left: {{ block.settings.section_padding_left_mobile }}px;
      padding-right: {{ block.settings.section_padding_right_mobile }}px;
      margin-top: {{ block.settings.section_margin_top_mobile }}px;
      margin-bottom: {{ block.settings.section_margin_bottom_mobile }}px;
    }

    .ai-about-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
      line-height: {{ block.settings.heading_line_height_mobile }};
      margin-bottom: {{ block.settings.heading_margin_bottom_mobile }}px;
    }

    .ai-about-subheading-{{ ai_gen_id }} {
      font-size: {{ block.settings.subheading_font_size_mobile }}px;
      line-height: {{ block.settings.subheading_line_height_mobile }};
      margin-top: {{ block.settings.subheading_margin_top_mobile }}px;
      margin-bottom: {{ block.settings.subheading_margin_bottom_mobile }}px;
    }

    .ai-about-content-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-about-image-wrapper-{{ ai_gen_id }},
    .ai-about-text-content-{{ ai_gen_id }} {
      order: 0;
    }

    .ai-about-image-{{ ai_gen_id }},
    .ai-about-image-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.image_height_mobile }}px;
      border-radius: {{ block.settings.image_border_radius_mobile }}px;
      box-shadow: {{ block.settings.image_shadow_horizontal_mobile }}px {{ block.settings.image_shadow_vertical_mobile }}px {{ block.settings.image_shadow_blur_mobile }}px {{ block.settings.image_shadow_spread_mobile }}px {{ block.settings.image_shadow_color }};
    }

    .ai-about-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size_mobile }}px;
      line-height: {{ block.settings.description_line_height_mobile }};
      margin-bottom: {{ block.settings.description_margin_bottom_mobile }}px;
    }

    .ai-about-stats-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.stats_columns_mobile }}, 1fr);
      gap: {{ block.settings.stats_gap_mobile }}px;
      margin-top: {{ block.settings.stats_margin_top_mobile }}px;
    }

    .ai-about-stat-item-{{ ai_gen_id }} {
      padding: {{ block.settings.stat_padding_mobile }}px;
      border-radius: {{ block.settings.stat_border_radius_mobile }}px;
    }

    .ai-about-stat-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_number_font_size_mobile }}px;
      line-height: {{ block.settings.stat_number_line_height_mobile }};
      margin-bottom: {{ block.settings.stat_number_margin_bottom_mobile }}px;
    }

    .ai-about-stat-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_label_font_size_mobile }}px;
      line-height: {{ block.settings.stat_label_line_height_mobile }};
    }
  }
{% endstyle %}

<div class="ai-about-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-about-container-{{ ai_gen_id }}">
    <div class="ai-about-content-grid-{{ ai_gen_id }}">
      {% if block.settings.layout != 'text-only' %}
        <div class="ai-about-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.image %}
            <img
              src="{{ block.settings.image | image_url: width: 1200 }}"
              alt="{{ block.settings.image.alt | escape }}"
              class="ai-about-image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.image.width }}"
              height="{{ block.settings.image.height }}"
            >
          {% else %}
            <div class="ai-about-image-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
      {% endif %}

      <div class="ai-about-text-content-{{ ai_gen_id }}">
        {% if block.settings.heading != blank or block.settings.subheading != blank %}
          <div class="ai-about-heading-wrapper-{{ ai_gen_id }}">
            {% if block.settings.heading != blank %}
              <div class="ai-about-subheading-{{ ai_gen_id }}">{{ block.settings.heading }}</div>
            {% endif %}
            {% if block.settings.subheading != blank %}
              <h2 class="ai-about-heading-{{ ai_gen_id }}">{{ block.settings.subheading }}</h2>
            {% endif %}
          </div>
        {% endif %}

        {% if block.settings.description != blank %}
          <div class="ai-about-description-{{ ai_gen_id }}">
            {{ block.settings.description }}
          </div>
        {% endif %}

        {% if block.settings.show_stats %}
          <div class="ai-about-stats-grid-{{ ai_gen_id }}">
            {% if block.settings.stat_1_number != blank %}
              <div class="ai-about-stat-item-{{ ai_gen_id }}">
                <div class="ai-about-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_1_number }}</div>
                <div class="ai-about-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_1_label }}</div>
              </div>
            {% endif %}

            {% if block.settings.stat_2_number != blank %}
              <div class="ai-about-stat-item-{{ ai_gen_id }}">
                <div class="ai-about-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_2_number }}</div>
                <div class="ai-about-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_2_label }}</div>
              </div>
            {% endif %}

            {% if block.settings.stat_3_number != blank %}
              <div class="ai-about-stat-item-{{ ai_gen_id }}">
                <div class="ai-about-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_3_number }}</div>
                <div class="ai-about-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_3_label }}</div>
              </div>
            {% endif %}

            {% if block.settings.stat_4_number != blank %}
              <div class="ai-about-stat-item-{{ ai_gen_id }}">
                <div class="ai-about-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_4_number }}</div>
                <div class="ai-about-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_4_label }}</div>
              </div>
            {% endif %}
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</div>

{% schema %}
