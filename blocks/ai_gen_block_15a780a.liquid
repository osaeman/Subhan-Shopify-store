{% endstyle %}

<top-selling-product-{{ ai_gen_id }} class="ai-top-selling-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-top-selling-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-top-selling-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-top-selling-content-{{ ai_gen_id }}">
      <div class="ai-top-selling-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 1000 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            class="ai-top-selling-image-{{ ai_gen_id }}"
            loading="lazy"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
          >
        {% else %}
          <div class="ai-top-selling-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}

        {% if block.settings.show_sale_badge and block.settings.sale_badge_text != blank %}
          <div class="ai-top-selling-sale-badge-{{ ai_gen_id }}">
            {{ block.settings.sale_badge_text }}
          </div>
        {% endif %}
      </div>

      <div class="ai-top-selling-text-content-{{ ai_gen_id }}">
        {% if block.settings.product_title != blank %}
          <h3 class="ai-top-selling-title-{{ ai_gen_id }}">{{ block.settings.product_title }}</h3>
        {% endif %}

        {% if block.settings.product_description != blank %}
          <div class="ai-top-selling-description-{{ ai_gen_id }}">{{ block.settings.product_description }}</div>
        {% endif %}

        <div class="ai-top-selling-sold-bar-{{ ai_gen_id }}">
          <div class="ai-top-selling-sold-text-{{ ai_gen_id }}">
            {{ block.settings.sold_text_prefix }} {{ block.settings.pieces_sold }} {{ block.settings.sold_text_suffix }}
          </div>
          <div class="ai-top-selling-progress-bar-{{ ai_gen_id }}">
            {% assign progress_percentage = block.settings.pieces_sold | times: 100 | divided_by: block.settings.total_stock %}
            {% if progress_percentage > 100 %}
              {% assign progress_percentage = 100 %}
            {% endif %}
            <div class="ai-top-selling-progress-fill-{{ ai_gen_id }}" style="width: {{ progress_percentage }}%;"></div>
          </div>
        </div>

        <div class="ai-top-selling-price-wrapper-{{ ai_gen_id }}">
          <span class="ai-top-selling-price-{{ ai_gen_id }}">{{ block.settings.product_price }}</span>
          {% if block.settings.compare_price != blank %}
            <span class="ai-top-selling-compare-price-{{ ai_gen_id }}">{{ block.settings.compare_price }}</span>
          {% endif %}
        </div>

        <a href="{{ block.settings.button_link }}" class="ai-top-selling-button-{{ ai_gen_id }}">
          {% if block.settings.button_show_icon %}
            <svg class="ai-top-selling-button-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          {% endif %}
          {{ block.settings.button_text }}
        </a>
      </div>
    </div>
  </div>
</top-selling-product-{{ ai_gen_id }}>

<script>
  (function() {
    class TopSellingProduct{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.initProgressBar();
      }

      initProgressBar() {
        const progressFill = this.querySelector('.ai-top-selling-progress-fill-{{ ai_gen_id }}');
        if (progressFill) {
          const targetWidth = progressFill.style.width;
          progressFill.style.width = '0%';
          setTimeout(function() {
            progressFill.style.width = targetWidth;
          }, 100);
        }
      }
    }

    customElements.define('top-selling-product-{{ ai_gen_id }}', TopSellingProduct{{ ai_gen_id }});
  })();
</script>

