{% doc %}
  @prompt
    I want you to design a section; the section will be about the top-selling product. The section will have a heading first, and then the section will have two boxes horizontally; the image option will be on the left side, and on the right side, there will be the textual part, which will contain the title of that product and the description text, a text bar that says how many pieces have already been sold, and a sleek and beautiful sale tag (placed somewhere appropriate—that also has the option to hide or display: none it as well where there is no sale). price of the product and a sleek, modern button or cart-shaped icon or button that will let the user proceed directly to the cart or order page. The overall design of the section must be sleek, modern, mimialist and elegant e-commerce UI. Also provide the control option for everything for every text, button, image, and tag (like margin, padding, size, color, line height, grid gap, and other important CSS styling properties for full accessibility for customization), and the section must be mobile and tablet responsive and provide full control alos for the mobile and tablet version )
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-top-selling-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px {{ block.settings.section_padding_horizontal }}px {{ block.settings.section_padding_bottom }}px {{ block.settings.section_padding_horizontal }}px;
    background-color: {{ block.settings.section_background_color }};
  }

  .ai-top-selling-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_max_width }}px;
    margin: 0 auto;
  }

  .ai-top-selling-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_font_size }}px;
    color: {{ block.settings.heading_color }};
    text-align: {{ block.settings.heading_alignment }};
    margin: 0 0 {{ block.settings.heading_margin_bottom }}px 0;
    line-height: {{ block.settings.heading_line_height }};
    font-weight: {{ block.settings.heading_font_weight }};
    letter-spacing: {{ block.settings.heading_letter_spacing }}px;
  }

  .ai-top-selling-content-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: {{ block.settings.image_width }}% {{ block.settings.content_width }}%;
    gap: {{ block.settings.grid_gap }}px;
    align-items: center;
  }

  .ai-top-selling-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.image_border_radius }}px;
    box-shadow: {{ block.settings.image_shadow_horizontal }}px {{ block.settings.image_shadow_vertical }}px {{ block.settings.image_shadow_blur }}px {{ block.settings.image_shadow_color }};
  }

  .ai-top-selling-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-top-selling-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1 / 1;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-top-selling-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-top-selling-sale-badge-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.sale_badge_position_top }}px;
    right: {{ block.settings.sale_badge_position_right }}px;
    background: {{ block.settings.sale_badge_background }};
    color: {{ block.settings.sale_badge_text_color }};
    padding: {{ block.settings.sale_badge_padding_vertical }}px {{ block.settings.sale_badge_padding_horizontal }}px;
    border-radius: {{ block.settings.sale_badge_border_radius }}px;
    font-size: {{ block.settings.sale_badge_font_size }}px;
    font-weight: {{ block.settings.sale_badge_font_weight }};
    letter-spacing: {{ block.settings.sale_badge_letter_spacing }}px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    z-index: 2;
  }

  .ai-top-selling-text-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding_top }}px {{ block.settings.content_padding_horizontal }}px {{ block.settings.content_padding_bottom }}px {{ block.settings.content_padding_horizontal }}px;
  }

  .ai-top-selling-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px 0;
    line-height: {{ block.settings.title_line_height }};
    font-weight: {{ block.settings.title_font_weight }};
    letter-spacing: {{ block.settings.title_letter_spacing }}px;
  }

  .ai-top-selling-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 {{ block.settings.description_margin_bottom }}px 0;
    line-height: {{ block.settings.description_line_height }};
    letter-spacing: {{ block.settings.description_letter_spacing }}px;
  }

  .ai-top-selling-sold-bar-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.sold_bar_margin_bottom }}px;
  }

  .ai-top-selling-sold-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.sold_text_font_size }}px;
    color: {{ block.settings.sold_text_color }};
    margin-bottom: {{ block.settings.sold_text_margin_bottom }}px;
    font-weight: {{ block.settings.sold_text_font_weight }};
  }

  .ai-top-selling-progress-bar-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.progress_bar_height }}px;
    background-color: {{ block.settings.progress_bar_background }};
    border-radius: {{ block.settings.progress_bar_border_radius }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-top-selling-progress-fill-{{ ai_gen_id }} {
    height: 100%;
    background: {{ block.settings.progress_bar_fill_color }};
    border-radius: {{ block.settings.progress_bar_border_radius }}px;
    transition: width 0.3s ease;
  }

  .ai-top-selling-price-wrapper-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.price_margin_bottom }}px;
  }

  .ai-top-selling-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_font_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: {{ block.settings.price_font_weight }};
    letter-spacing: {{ block.settings.price_letter_spacing }}px;
  }

  .ai-top-selling-compare-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.compare_price_font_size }}px;
    color: {{ block.settings.compare_price_color }};
    text-decoration: line-through;
    margin-left: {{ block.settings.compare_price_margin_left }}px;
  }

  .ai-top-selling-button-{{ ai_gen_id }} {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: {{ block.settings.button_icon_gap }}px;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: {{ block.settings.button_font_weight }};
    letter-spacing: {{ block.settings.button_letter_spacing }}px;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-top-selling-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
    transform: translateY(-2px);
  }

  .ai-top-selling-button-icon-{{ ai_gen_id }} {
    width: {{ block.settings.button_icon_size }}px;
    height: {{ block.settings.button_icon_size }}px;
  }

  @media screen and (max-width: 989px) {
    .ai-top-selling-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_tablet }}px {{ block.settings.section_padding_horizontal_tablet }}px {{ block.settings.section_padding_bottom_tablet }}px {{ block.settings.section_padding_horizontal_tablet }}px;
    }

    .ai-top-selling-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_tablet }}px;
      margin-bottom: {{ block.settings.heading_margin_bottom_tablet }}px;
    }

    .ai-top-selling-content-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.grid_gap_tablet }}px;
    }

    .ai-top-selling-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_tablet }}px;
    }

    .ai-top-selling-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size_tablet }}px;
    }

    .ai-top-selling-text-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_top_tablet }}px {{ block.settings.content_padding_horizontal_tablet }}px {{ block.settings.content_padding_bottom_tablet }}px {{ block.settings.content_padding_horizontal_tablet }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-top-selling-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px {{ block.settings.section_padding_bottom_mobile }}px {{ block.settings.section_padding_horizontal_mobile }}px;
    }

    .ai-top-selling-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_font_size_mobile }}px;
      margin-bottom: {{ block.settings.heading_margin_bottom_mobile }}px;
    }

    .ai-top-selling-content-{{ ai_gen_id }} {
      gap: {{ block.settings.grid_gap_mobile }}px;
    }

    .ai-top-selling-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size_mobile }}px;
    }

    .ai-top-selling-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size_mobile }}px;
    }

    .ai-top-selling-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_font_size_mobile }}px;
    }

    .ai-top-selling-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
      padding: {{ block.settings.button_padding_vertical_mobile }}px {{ block.settings.button_padding_horizontal_mobile }}px;
    }

    .ai-top-selling-text-content-{{ ai_gen_id }} {
      padding: {{ block.settings.content_padding_top_mobile }}px {{ block.settings.content_padding_horizontal_mobile }}px {{ block.settings.content_padding_bottom_mobile }}px {{ block.settings.content_padding_horizontal_mobile }}px;
    }
