{% doc %}
  @prompt
    Now in this footer section. Customize this footer section with a sleek and minimalist design and add address, email, phone number, and social media icons for Facebook, Instagram, TikTok, and WhatsApp. (for social media icon design, you have to follow this code - <style> 
    .social-icons-wrapper {
      text-align: center; /* change to left or right if needed */
      margin: 0 0;
    }
    
    .social-icons {
      display: inline-flex;
      gap: 15px;
    }
    
    .social-icons a {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 45px;
      height: 45px;
      border-radius: 40%;
      text-decoration: none;
      transition: 0.3s ease;
    }
    
    .social-icons svg {
      width: 20px;
      height: 20px;
      fill: white;
    }
    
    /* Brand Colors */
    .facebook { background-color: #1877F2; }
    .instagram { background: linear-gradient(45deg,#f9ce34,#ee2a7b,#6228d7); }
    .tiktok { background-color: #000000; }
    
    /* Hover Effect */
    .social-icons a:hover {
      transform: scale(1.1);
      opacity: 0.85;
    }
    </style>
    
    <div class="social-icons-wrapper">
      <div class="social-icons">
        
        <!-- Facebook -->
        <a href="https://www.facebook.com/yourpage" target="_blank" class="facebook">
          <svg viewBox="0 0 24 24">
            <path d="M22 12.07C22 6.49 17.52 2 12 2S2 6.49 2 12.07c0 5.03 3.66 9.2 8.44 9.93v-7.02H7.9v-2.91h2.54V9.84c0-2.5 1.49-3.88 3.77-3.88 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.44 2.91h-2.34V22c4.78-.73 8.44-4.9 8.44-9.93z"/>
          </svg>
        </a>
    
        <!-- Instagram -->
        <a href="https://www.instagram.com/yourpage" target="_blank" class="instagram">
          <svg viewBox="0 0 24 24">
            <path d="M7.75 2C4.57 2 2 4.57 2 7.75v8.5C2 19.43 4.57 22 7.75 22h8.5C19.43 22 22 19.43 22 16.25v-8.5C22 4.57 19.43 2 16.25 2h-8.5zm4.25 5.5A4.75 4.75 0 1 1 7.25 12 4.75 4.75 0 0 1 12 7.5zm5.25-.75a1.25 1.25 0 1 1-1.25 1.25 1.25 1.25 0 0 1 1.25-1.25z"/>
          </svg>
        </a>
    
        <!-- TikTok -->
        <a href="https://www.tiktok.com/@yourpage" target="_blank" class="tiktok">
          <svg viewBox="0 0 24 24">
            <path d="M16 2c.3 1.7 1.3 3.1 2.7 4 1 .6 2.1.9 3.3.9v3c-1.4 0-2.8-.3-4-1v6.5A6.5 6.5 0 1 1 11.5 9h3v3a3.5 3.5 0 1 0 3.5 3.5V2h-2z"/>
          </svg>
        </a>
    
      </div>
    </div>Provide every control so I can easily customize/tweak element properties or CSS styling, and the design layout and text must be mobile and tab responsive and friendly., Rest is alright. 1) provide padding option for the bottom text, as this section is just beneath the social section. 2) there is no need for the Quick links section and About us section., Now as the Contact us part will only be the section in the top part so there is no need for horizontal grid, provide the position adjustment options for the Contact us part also, so i can easliy adjust that part either in center or in left what ever suits better, Do one more thing: provide the option to center-align the text and heading also for the "Contact Us" part. and make the icons of the address, mail and phone stylish and colorful if possible, like the social media icons
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-footer-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
  }

  .ai-footer-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-footer-contact-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.contact_alignment }};
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-footer-contact-content-{{ ai_gen_id }} {
    display: inline-block;
    {% if block.settings.contact_text_alignment == 'center' %}
      text-align: center;
    {% else %}
      text-align: left;
    {% endif %}
  }

  .ai-footer-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
    {% if block.settings.contact_text_alignment == 'center' %}
      align-items: center;
    {% else %}
      align-items: flex-start;
    {% endif %}
  }

  .ai-footer-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    font-weight: {{ block.settings.heading_weight }};
    margin: 0 0 {{ block.settings.heading_margin }}px 0;
    color: {{ block.settings.heading_color }};
  }

  .ai-footer-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: {{ block.settings.line_height }};
    margin: 0;
    color: {{ block.settings.text_color }};
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-footer-link-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    text-decoration: none;
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-footer-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-footer-icon-wrapper-{{ ai_gen_id }} {
    width: {{ block.settings.contact_icon_size }}px;
    height: {{ block.settings.contact_icon_size }}px;
    border-radius: {{ block.settings.contact_icon_border_radius }}%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  .ai-footer-link-{{ ai_gen_id }}:hover .ai-footer-icon-wrapper-{{ ai_gen_id }} {
    transform: scale({{ block.settings.contact_icon_hover_scale }});
  }

  .ai-footer-icon-address-{{ ai_gen_id }} {
    background: {{ block.settings.address_icon_gradient }};
  }

  .ai-footer-icon-email-{{ ai_gen_id }} {
    background: {{ block.settings.email_icon_gradient }};
  }

  .ai-footer-icon-phone-{{ ai_gen_id }} {
    background: {{ block.settings.phone_icon_gradient }};
  }

  .ai-footer-icon-wrapper-{{ ai_gen_id }} svg {
    width: {{ block.settings.contact_icon_svg_size }}px;
    height: {{ block.settings.contact_icon_svg_size }}px;
    stroke: {{ block.settings.contact_icon_color }};
    fill: none;
  }

  .ai-footer-social-wrapper-{{ ai_gen_id }} {
    text-align: {{ block.settings.social_alignment }};
    margin-top: {{ block.settings.social_margin_top }}px;
  }

  .ai-footer-social-icons-{{ ai_gen_id }} {
    display: inline-flex;
    gap: {{ block.settings.social_gap }}px;
    flex-wrap: wrap;
  }

  .ai-footer-social-icons-{{ ai_gen_id }} a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.social_icon_size }}px;
    height: {{ block.settings.social_icon_size }}px;
    border-radius: {{ block.settings.social_border_radius }}%;
    text-decoration: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .ai-footer-social-icons-{{ ai_gen_id }} svg {
    width: {{ block.settings.social_svg_size }}px;
    height: {{ block.settings.social_svg_size }}px;
    fill: white;
  }

  .ai-footer-facebook-{{ ai_gen_id }} {
    background-color: {{ block.settings.facebook_color }};
  }

  .ai-footer-instagram-{{ ai_gen_id }} {
    background: {{ block.settings.instagram_gradient }};
  }

  .ai-footer-tiktok-{{ ai_gen_id }} {
    background-color: {{ block.settings.tiktok_color }};
  }

  .ai-footer-whatsapp-{{ ai_gen_id }} {
    background-color: {{ block.settings.whatsapp_color }};
  }

  .ai-footer-social-icons-{{ ai_gen_id }} a:hover {
    transform: scale({{ block.settings.social_hover_scale }});
    opacity: {{ block.settings.social_hover_opacity }};
  }

  .ai-footer-divider-{{ ai_gen_id }} {
    height: 1px;
    background-color: {{ block.settings.divider_color }};
    margin: {{ block.settings.divider_margin }}px 0;
    opacity: {{ block.settings.divider_opacity }};
  }

  .ai-footer-bottom-{{ ai_gen_id }} {
    text-align: {{ block.settings.bottom_text_alignment }};
    font-size: {{ block.settings.bottom_text_size }}px;
    color: {{ block.settings.text_color }};
    padding-top: {{ block.settings.bottom_text_padding_top }}px;
    padding-bottom: {{ block.settings.bottom_text_padding_bottom }}px;
  }

  @media screen and (max-width: 768px) {
    .ai-footer-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_padding_top }}px {{ block.settings.mobile_padding_horizontal }}px {{ block.settings.mobile_padding_bottom }}px;
    }

    .ai-footer-contact-wrapper-{{ ai_gen_id }} {
      text-align: {{ block.settings.mobile_contact_alignment }};
    }

    .ai-footer-contact-content-{{ ai_gen_id }} {
      {% if block.settings.mobile_contact_text_alignment == 'center' %}
        text-align: center;
      {% else %}
        text-align: left;
      {% endif %}
    }

    .ai-footer-column-{{ ai_gen_id }} {
      {% if block.settings.mobile_contact_text_alignment == 'center' %}
        align-items: center;
      {% else %}
        align-items: flex-start;
      {% endif %}
    }

    .ai-footer-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_heading_size }}px;
    }

    .ai-footer-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_text_size }}px;
    }

    .ai-footer-social-wrapper-{{ ai_gen_id }} {
      text-align: {{ block.settings.mobile_social_alignment }};
    }

    .ai-footer-social-icons-{{ ai_gen_id }} {
      justify-content: {{ block.settings.mobile_social_alignment }};
    }

    .ai-footer-bottom-{{ ai_gen_id }} {
      text-align: {{ block.settings.mobile_bottom_text_alignment }};
      font-size: {{ block.settings.mobile_bottom_text_size }}px;
      padding-top: {{ block.settings.mobile_bottom_text_padding_top }}px;
      padding-bottom: {{ block.settings.mobile_bottom_text_padding_bottom }}px;
    }
  }
{% endstyle %}

<footer-block-{{ ai_gen_id }} class="ai-footer-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-footer-container-{{ ai_gen_id }}">
    {% if block.settings.show_contact_info %}
      <div class="ai-footer-contact-wrapper-{{ ai_gen_id }}">
        <div class="ai-footer-contact-content-{{ ai_gen_id }}">
          <div class="ai-footer-column-{{ ai_gen_id }}">
            {% if block.settings.contact_heading != blank %}
              <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ block.settings.contact_heading }}</h3>
            {% endif %}

            {% if block.settings.address != blank %}
              <div class="ai-footer-text-{{ ai_gen_id }}">
                <div class="ai-footer-icon-wrapper-{{ ai_gen_id }} ai-footer-icon-address-{{ ai_gen_id }}">
                  <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                    <circle cx="12" cy="10" r="3"></circle>
                  </svg>
                </div>
                <span>{{ block.settings.address }}</span>
              </div>
            {% endif %}

            {% if block.settings.email != blank %}
              <a href="mailto:{{ block.settings.email }}" class="ai-footer-link-{{ ai_gen_id }}">
                <div class="ai-footer-icon-wrapper-{{ ai_gen_id }} ai-footer-icon-email-{{ ai_gen_id }}">
                  <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                    <polyline points="22,6 12,13 2,6"></polyline>
                  </svg>
                </div>
                <span>{{ block.settings.email }}</span>
              </a>
            {% endif %}

            {% if block.settings.phone != blank %}
              <a href="tel:{{ block.settings.phone }}" class="ai-footer-link-{{ ai_gen_id }}">
                <div class="ai-footer-icon-wrapper-{{ ai_gen_id }} ai-footer-icon-phone-{{ ai_gen_id }}">
                  <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
                  </svg>
                </div>
                <span>{{ block.settings.phone }}</span>
              </a>
            {% endif %}
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_social %}
      <div class="ai-footer-social-wrapper-{{ ai_gen_id }}">
        {% if block.settings.social_heading != blank %}
          <h3 class="ai-footer-heading-{{ ai_gen_id }}">{{ block.settings.social_heading }}</h3>
        {% endif %}
        <div class="ai-footer-social-icons-{{ ai_gen_id }}">
          {% if block.settings.facebook_url != blank %}
            <a href="{{ block.settings.facebook_url }}" target="_blank" rel="noopener" class="ai-footer-facebook-{{ ai_gen_id }}" aria-label="Facebook">
              <svg viewBox="0 0 24 24">
                <path d="M22 12.07C22 6.49 17.52 2 12 2S2 6.49 2 12.07c0 5.03 3.66 9.2 8.44 9.93v-7.02H7.9v-2.91h2.54V9.84c0-2.5 1.49-3.88 3.77-3.88 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.87h2.78l-.44 2.91h-2.34V22c4.78-.73 8.44-4.9 8.44-9.93z"/>
              </svg>
            </a>
          {% endif %}

          {% if block.settings.instagram_url != blank %}
            <a href="{{ block.settings.instagram_url }}" target="_blank" rel="noopener" class="ai-footer-instagram-{{ ai_gen_id }}" aria-label="Instagram">
              <svg viewBox="0 0 24 24">
                <path d="M7.75 2C4.57 2 2 4.57 2 7.75v8.5C2 19.43 4.57 22 7.75 22h8.5C19.43 22 22 19.43 22 16.25v-8.5C22 4.57 19.43 2 16.25 2h-8.5zm4.25 5.5A4.75 4.75 0 1 1 7.25 12 4.75 4.75 0 0 1 12 7.5zm5.25-.75a1.25 1.25 0 1 1-1.25 1.25 1.25 1.25 0 0 1 1.25-1.25z"/>
              </svg>
            </a>
          {% endif %}

          {% if block.settings.tiktok_url != blank %}
            <a href="{{ block.settings.tiktok_url }}" target="_blank" rel="noopener" class="ai-footer-tiktok-{{ ai_gen_id }}" aria-label="TikTok">
              <svg viewBox="0 0 24 24">
                <path d="M16 2c.3 1.7 1.3 3.1 2.7 4 1 .6 2.1.9 3.3.9v3c-1.4 0-2.8-.3-4-1v6.5A6.5 6.5 0 1 1 11.5 9h3v3a3.5 3.5 0 1 0 3.5 3.5V2h-2z"/>
              </svg>
            </a>
          {% endif %}

          {% if block.settings.whatsapp_url != blank %}
            <a href="{{ block.settings.whatsapp_url }}" target="_blank" rel="noopener" class="ai-footer-whatsapp-{{ ai_gen_id }}" aria-label="WhatsApp">
              <svg viewBox="0 0 24 24">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
              </svg>
            </a>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if block.settings.show_divider %}
      <div class="ai-footer-divider-{{ ai_gen_id }}"></div>
    {% endif %}

    {% if block.settings.bottom_text != blank %}
      <div class="ai-footer-bottom-{{ ai_gen_id }}">
        {{ block.settings.bottom_text }}
      </div>
    {% endif %}
  </div>
</footer-block-{{ ai_gen_id }}>

<script>
  (function() {
    class FooterBlock{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.init();
      }

      init() {
        const currentYear = new Date().getFullYear();
        const yearElements = this.querySelectorAll('[data-year]');
        yearElements.forEach(el => {
          el.textContent = currentYear;
        });
      }
    }

    customElements.define('footer-block-{{ ai_gen_id }}', FooterBlock{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Minimalist footer",
  "tag": null,
  "settings": [
    {
      "type": "header",
