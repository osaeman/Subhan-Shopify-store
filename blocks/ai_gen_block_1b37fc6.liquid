{% doc %}
  @prompt
    Just like the current featured product section. Design clean, modern, sleek, minimalist, and unique card designs. Should display a set of 4 cards just like the current one. the text on the card should be left-aligned and must be in size hierarchy; cards and images should have a nice and subtle animation.  Also provide options to increase or decrase sizes, margins or paddings, so i can tweek a little bit according to my requiremnet or desire
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-feature-cards-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
  }

  .ai-feature-cards__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.container_width }}px;
    margin: 0 auto;
    padding: 0 {{ block.settings.container_padding }}px;
  }

  .ai-feature-cards__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: {{ block.settings.card_gap }}px;
  }

  .ai-feature-cards__card-{{ ai_gen_id }} {
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1), box-shadow 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity }});
  }

  .ai-feature-cards__card-{{ ai_gen_id }}:hover {
    transform: translateY(-{{ block.settings.card_hover_lift }}px);
    box-shadow: 0 {{ block.settings.card_shadow_y | plus: 8 }}px {{ block.settings.card_shadow_blur | plus: 12 }}px rgba(0, 0, 0, {{ block.settings.card_shadow_opacity | plus: 0.1 }});
  }

  .ai-feature-cards__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-top: {{ block.settings.image_aspect_ratio }}%;
    overflow: hidden;
    background: #f4f4f4;
  }

  .ai-feature-cards__image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .ai-feature-cards__card-{{ ai_gen_id }}:hover .ai-feature-cards__image-{{ ai_gen_id }} {
    transform: scale(1.05);
  }

  .ai-feature-cards__image-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f4f4f4;
  }

  .ai-feature-cards__image-placeholder-{{ ai_gen_id }} svg {
    width: 50%;
    height: 50%;
    opacity: 0.3;
  }

  .ai-feature-cards__content-{{ ai_gen_id }} {
    padding: {{ block.settings.card_content_padding }}px;
    text-align: left;
  }

  .ai-feature-cards__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    font-weight: {{ block.settings.title_font_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin_bottom }}px;
    line-height: 1.3;
  }

  .ai-feature-cards__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_font_size }}px;
    font-weight: {{ block.settings.subtitle_font_weight }};
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 {{ block.settings.subtitle_margin_bottom }}px;
    line-height: 1.4;
  }

  .ai-feature-cards__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_font_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.6;
  }

  @media screen and (max-width: 989px) {
    .ai-feature-cards__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(2, 1fr);
      gap: {{ block.settings.card_gap | times: 0.75 }}px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-feature-cards__grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.card_gap | times: 0.5 }}px;
    }

    .ai-feature-cards__container-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.container_padding | times: 0.5 }}px;
    }

    .ai-feature-cards__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_font_size | times: 0.9 }}px;
    }

    .ai-feature-cards__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_font_size | times: 0.9 }}px;
    }

    .ai-feature-cards__description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<feature-cards-{{ ai_gen_id }} class="ai-feature-cards-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-feature-cards__container-{{ ai_gen_id }}">
    <div class="ai-feature-cards__grid-{{ ai_gen_id }}">
      {% for i in (1..4) %}
        {% liquid
          assign image_key = 'card_' | append: i | append: '_image'
          assign title_key = 'card_' | append: i | append: '_title'
          assign subtitle_key = 'card_' | append: i | append: '_subtitle'
          assign description_key = 'card_' | append: i | append: '_description'
          
          assign card_image = block.settings[image_key]
          assign card_title = block.settings[title_key]
          assign card_subtitle = block.settings[subtitle_key]
          assign card_description = block.settings[description_key]
        %}
        
        <div class="ai-feature-cards__card-{{ ai_gen_id }}">
          <div class="ai-feature-cards__image-wrapper-{{ ai_gen_id }}">
            {% if card_image %}
              <img
                src="{{ card_image | image_url: width: 800 }}"
                alt="{{ card_image.alt | escape }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                class="ai-feature-cards__image-{{ ai_gen_id }}"
              >
            {% else %}
              <div class="ai-feature-cards__image-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>
          
          <div class="ai-feature-cards__content-{{ ai_gen_id }}">
            {% if card_title != blank %}
              <h3 class="ai-feature-cards__title-{{ ai_gen_id }}">{{ card_title }}</h3>
            {% endif %}
            
            {% if card_subtitle != blank %}
              <p class="ai-feature-cards__subtitle-{{ ai_gen_id }}">{{ card_subtitle }}</p>
            {% endif %}
            
            {% if card_description != blank %}
              <div class="ai-feature-cards__description-{{ ai_gen_id }}">{{ card_description }}</div>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</feature-cards-{{ ai_gen_id }}>

<script>
  (function() {
    class FeatureCards{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-feature-cards__card-{{ ai_gen_id }}');
        this.setupObserver();
      }

      setupObserver() {
        const observerOptions = {
          threshold: 0.1,
          rootMargin: '0px 0px -50px 0px'
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry, index) => {
            if (entry.isIntersecting) {
              setTimeout(() => {
                entry.target.style.opacity = '1';
                entry.target.style.transform = 'translateY(0)';
              }, index * 100);
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        this.cards.forEach((card) => {
          card.style.opacity = '0';
          card.style.transform = 'translateY(20px)';
          card.style.transition = 'opacity 0.6s ease, transform 0.6s ease';
          observer.observe(card);
        });
      }
    }

    customElements.define('feature-cards-{{ ai_gen_id }}', FeatureCards{{ ai_gen_id }});
  })();
</script>

